#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Render needs the HTTP port to open promptly. Prepare the remote database in a
# bounded background task so a slow TiDB migration cannot block Puma startup.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # The Puma plugin starts Solid Queue before the background db:prepare has
  # created its tables. Run it independently after preparation instead so a
  # queue startup failure cannot take the Render web process down.
  run_solid_queue="${SOLID_QUEUE_IN_PUMA:-false}"
  export SOLID_QUEUE_IN_PUMA=false

  (
    echo "==> Preparing database in the background..."
    if timeout "${DB_PREPARE_TIMEOUT:-240}" ./bin/rails db:prepare; then
      echo "==> Database preparation completed."
      if [ "${SEED_DEMO_DATA:-false}" = "true" ]; then
        echo "==> Seeding demo data..."
        # Demo seeds update thousands of records. Audit rows are useful for
        # user actions, but add substantial remote-database latency here.
        if DISABLE_AUDIT_EVENTS=true timeout "${DB_SEED_TIMEOUT:-600}" ./bin/rails db:seed; then
          echo "==> Demo data seeding completed."
        else
          echo "==> Demo data seeding failed or timed out; web service remains available."
        fi
      fi

      if [ "${run_solid_queue}" = "true" ]; then
        echo "==> Starting Solid Queue after database preparation..."
        exec ./bin/jobs
      fi
    else
      echo "==> Database preparation failed or timed out; check the database logs."
    fi
  ) &
fi

exec "${@}"
