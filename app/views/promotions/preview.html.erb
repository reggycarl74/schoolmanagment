<% content_for :title, "Preview promotion · SchoolOS" %><h1 class="text-3xl font-black">Preview promotion</h1><p class="mt-2 text-slate-500">Review this change before submitting it. No enrollment has been changed yet.</p><div class="mt-6 rounded-3xl border bg-white p-7"><div class="grid gap-4 rounded-2xl bg-indigo-50 p-5 sm:grid-cols-2"><div><p class="text-xs font-bold uppercase text-indigo-500">From</p><p class="mt-1 text-xl font-black"><%= @from_classroom.name %></p><p class="text-sm"><%= @from_classroom.academic_year.name %></p></div><div><p class="text-xs font-bold uppercase text-indigo-500">To</p><p class="mt-1 text-xl font-black"><%= @target_classroom.name %></p><p class="text-sm"><%= @target_classroom.academic_year.name %></p></div></div><h2 class="mt-6 font-bold"><%= @selected_enrollments.size %> selected students</h2><ul class="mt-3 grid gap-2 sm:grid-cols-2"><% @selected_enrollments.each do |enrollment| %><li class="rounded-xl bg-slate-50 p-3"><%= enrollment.student.full_name %></li><% end %></ul><%= form_with url: promotion_path, class: "mt-6" do %><%= hidden_field_tag :confirmed, "1" %><%= hidden_field_tag :from_classroom_id, @from_classroom.id %><%= hidden_field_tag :to_classroom_id, @target_classroom.id %><%= hidden_field_tag :reason, @reason %><% @selected_enrollments.each do |enrollment| %><%= hidden_field_tag "student_ids[]", enrollment.student_id %><% end %><div class="flex gap-3"><%= link_to "Go back", new_promotion_path(from_classroom_id: @from_classroom.id), class: "rounded-xl bg-slate-100 px-5 py-3 font-bold" %><%= submit_tag(current_user.administrator? ? "Confirm promotion" : "Submit for approval", class: "primary-button") %></div><% end %></div>
