<% content_for :title, "Promote students · SchoolOS" %><h1 class="text-3xl font-bold">Promote students</h1><% if current_user.teacher? %><p class="mt-2 text-sm text-slate-500">You can request promotions only from assigned classes. An administrator must approve the request.</p><% end %><%= form_with url: new_promotion_path, method: :get, class: "mt-6 flex items-end gap-4 rounded-2xl border bg-white p-5" do |f| %><div class="flex-1"><%= f.label :from_classroom_id, "Current class", class: "field-label" %><%= f.collection_select :from_classroom_id, @source_classrooms, :id, :name, { prompt: "Select class", selected: params[:from_classroom_id] }, class: "form-input" %></div><%= f.submit "Load students", class: "primary-button" %><% end %><% if @from_classroom %><%= form_with url: promotion_path, method: :post, class: "mt-6 rounded-2xl border bg-white p-6" do |f| %><%= hidden_field_tag :from_classroom_id, @from_classroom.id %><div class="grid gap-4 sm:grid-cols-2"><div><%= label_tag :to_classroom_id, "Promote to", class: "field-label" %><%= select_tag :to_classroom_id, options_from_collection_for_select(@destination_classrooms.reject { |classroom| classroom.id == @from_classroom.id }, :id, :name), prompt: "Select destination", required: true, class: "form-input" %></div><div><%= label_tag :reason, "Promotion reason", class: "field-label" %><%= text_field_tag :reason, nil, required: true, placeholder: "End-of-year promotion", class: "form-input" %></div></div><div class="mt-6 divide-y"><% @enrollments.each do |entry| %><label class="flex gap-3 py-3"><%= check_box_tag "student_ids[]", entry.student_id, true %><%= entry.student.full_name %></label><% end %></div><%= f.submit "Preview promotion", class: "primary-button mt-5" %><% end %><% end %><section class="mt-8 rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Promotion history and approvals</h2><div class="mt-4 space-y-3"><% @promotion_batches.each do |batch| %><article class="rounded-xl bg-slate-50 p-4"><div class="flex flex-wrap items-center justify-between gap-3"><div><strong><%= batch.from_classroom.name %> → <%= batch.to_classroom.name %></strong><p class="text-xs text-slate-500"><%= batch.promotion_items.size %> students · requested by <%= batch.initiated_by.full_name %> · <%= batch.reason %></p></div><span class="rounded-full bg-white px-3 py-1 text-xs font-bold"><%= batch.status.humanize %></span></div><% if current_user.administrator? %><div class="mt-3 flex gap-3"><% if batch.pending? %><%= button_to "Approve", approve_promotion_path(batch), class: "text-sm font-bold text-emerald-700" %><% elsif batch.approved? %><%= button_to "Reverse", reverse_promotion_path(batch), class: "text-sm font-bold text-red-700", form: { data: { turbo_confirm: "Reverse this entire promotion batch?" } } %><% end %></div><% end %></article><% end %><% if @promotion_batches.empty? %><p class="text-sm text-slate-500">No promotion requests yet.</p><% end %></div></section>
