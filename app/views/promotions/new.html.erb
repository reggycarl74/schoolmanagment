<% content_for :title, "Promote students · SchoolOS" %><h1 class="text-3xl font-bold">Promote students</h1><%= form_with url: new_promotion_path, method: :get, class: "mt-6 flex items-end gap-4 rounded-2xl border bg-white p-5" do |f| %><div class="flex-1"><%= f.label :from_classroom_id, "Current class", class: "field-label" %><%= f.collection_select :from_classroom_id, @classrooms, :id, :name, { prompt: "Select class", selected: params[:from_classroom_id] }, class: "form-input" %></div><%= f.submit "Load students", class: "primary-button" %><% end %><% if @from_classroom %><%= form_with url: promotion_path, method: :post, class: "mt-6 rounded-2xl border bg-white p-6" do |f| %><%= hidden_field_tag :from_classroom_id, @from_classroom.id %><div><%= label_tag :to_classroom_id, "Promote to", class: "field-label" %><%= collection_select_tag :to_classroom_id, @classrooms.reject { |c| c.id == @from_classroom.id }, :id, :name, { prompt: "Select destination" }, required: true, class: "form-input" %></div><div class="mt-6 divide-y"><% @enrollments.each do |entry| %><label class="flex gap-3 py-3"><%= check_box_tag "student_ids[]", entry.student_id, true %><%= entry.student.full_name %></label><% end %></div><%= f.submit "Promote selected students", class: "primary-button mt-5", data: { turbo_confirm: "Promote the selected students?" } %><% end %><% end %>
