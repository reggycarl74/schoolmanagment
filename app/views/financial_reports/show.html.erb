<% content_for :title, "Financial report · SchoolOS" %><h1 class="text-3xl font-black">Financial report</h1><p class="mt-2 text-slate-500">Collections, receivables, and overdue aging.</p>
<%= form_with url: financial_report_path, method: :get, class: "mt-6 flex flex-wrap items-end gap-4 rounded-2xl border bg-white p-5" do |form| %><div><%= form.label :from, class: "field-label" %><%= form.date_field :from, value: @from, class: "form-input" %></div><div><%= form.label :to, class: "field-label" %><%= form.date_field :to, value: @to, class: "form-input" %></div><%= form.submit "Apply", class: "primary-button" %><%= link_to "Export CSV", financial_report_path(from: @from, to: @to, format: :csv), class: "rounded-xl bg-emerald-50 px-5 py-3 text-sm font-bold text-emerald-700" %><% end %>
<div class="mt-6 grid gap-4 md:grid-cols-3"><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Total invoiced</p><p class="mt-2 text-3xl font-black"><%= money(@invoiced) %></p></div><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Collected in period</p><p class="mt-2 text-3xl font-black text-emerald-700"><%= money(@collected) %></p></div><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Outstanding</p><p class="mt-2 text-3xl font-black text-amber-700"><%= money(@outstanding) %></p></div></div>
<section class="mt-6 rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Receivables aging</h2><div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5"><% @aging.each do |label, amount| %><div class="rounded-xl bg-slate-50 p-4"><p class="text-xs font-bold text-slate-500"><%= label %></p><p class="mt-2 text-lg font-black"><%= money(amount) %></p></div><% end %></div></section>
<div class="mt-6 overflow-x-auto rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Recent payments</h2><table class="mt-4 w-full min-w-[650px] text-left"><thead><tr class="border-b"><th class="py-3">Receipt</th><th>Date</th><th>Student</th><th>Method</th><th class="text-right">Amount</th></tr></thead><tbody><% @payments.includes(invoice: :student).order(paid_on: :desc).limit(100).each do |payment| %><tr class="border-b"><td class="py-3"><%= link_to payment.receipt_number, invoice_payment_path(payment.invoice, payment), class: "font-bold text-indigo-700" %></td><td><%= payment.paid_on %></td><td><%= payment.invoice.student.full_name %></td><td><%= payment.payment_method.humanize %></td><td class="text-right"><%= money(payment.amount) %></td></tr><% end %></tbody></table></div>
