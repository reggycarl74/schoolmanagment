<% content_for :title, "Financial report · SchoolOS" %><h1 class="text-3xl font-bold">Financial report</h1><p class="mt-2 text-slate-500">Collections for the selected period and the school's current receivables.</p>
<%= form_with url: financial_report_path, method: :get, class: "mt-6 flex flex-wrap items-end gap-4 rounded-2xl border bg-white p-5" do |form| %><div><%= form.label :from, class: "field-label" %><%= form.date_field :from, value: @from, class: "form-input" %></div><div><%= form.label :to, class: "field-label" %><%= form.date_field :to, value: @to, class: "form-input" %></div><%= form.submit "Apply", class: "primary-button" %></div><% end %>
<div class="mt-6 grid gap-4 md:grid-cols-3"><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Total invoiced</p><p class="mt-2 text-3xl font-bold"><%= number_to_currency(@invoiced) %></p></div><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Collected in period</p><p class="mt-2 text-3xl font-bold text-emerald-700"><%= number_to_currency(@collected) %></p></div><div class="rounded-2xl border bg-white p-6"><p class="text-sm text-slate-500">Outstanding</p><p class="mt-2 text-3xl font-bold text-amber-700"><%= number_to_currency(@outstanding) %></p></div></div>
<div class="mt-6 rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Recent payments</h2><table class="mt-4 w-full text-left"><thead><tr class="border-b"><th class="py-3">Date</th><th>Student</th><th>Method</th><th class="text-right">Amount</th></tr></thead><tbody><% @payments.includes(invoice: :student).order(paid_on: :desc).limit(100).each do |payment| %><tr class="border-b"><td class="py-3"><%= payment.paid_on %></td><td><%= payment.invoice.student.full_name %></td><td><%= payment.payment_method.humanize %></td><td class="text-right"><%= number_to_currency(payment.amount) %></td></tr><% end %></tbody></table></div>
