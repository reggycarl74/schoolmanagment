<% content_for :title, "Assessment settings · SchoolOS" %><h1 class="text-3xl font-bold">Assessment settings</h1><div class="mt-8 grid gap-8 lg:grid-cols-2"><section class="rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Assessment components</h2><div class="mt-4 divide-y"><% @components.each do |item| %><p class="flex justify-between py-3"><span><%= item.title %></span><strong><%= item.maximum_points %></strong></p><% end %></div><%= form_with url: assessment_settings_path, scope: :assessment_component, class: "mt-6 grid gap-3" do |f| %><%= hidden_field_tag :setting_type, "component" %><%= f.text_field :title, placeholder: "Component name", class: "form-input" %><%= f.number_field :maximum_points, placeholder: "Maximum", class: "form-input" %><%= f.select :kind, Assessment.kinds.keys.map { |k| [k.humanize, k] }, {}, class: "form-input" %><%= f.number_field :position, placeholder: "Position", class: "form-input" %><%= f.submit "Add component", class: "primary-button" %><% end %></section><section class="rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Grade bands</h2><div class="mt-4 divide-y"><% @scales.each do |scale| %><p class="flex justify-between py-3"><span><strong><%= scale.letter %></strong> · <%= scale.remark %></span><span><%= scale.minimum_percentage %>%+</span></p><% end %></div><%= form_with url: assessment_settings_path, scope: :grading_scale, class: "mt-6 grid gap-3" do |f| %><%= hidden_field_tag :setting_type, "scale" %><%= f.text_field :letter, placeholder: "Grade (A)", class: "form-input" %><%= f.number_field :minimum_percentage, placeholder: "Minimum percentage", class: "form-input" %><%= f.text_field :remark, placeholder: "Remark", class: "form-input" %><%= f.submit "Add grade band", class: "primary-button" %><% end %></section></div>
