<% content_for :title, "Assessment settings · SchoolOS" %><h1 class="text-3xl font-bold">Assessment and report workflow</h1>
<%= form_with url: assessment_settings_path, method: :get, class: "mt-6 flex gap-3 rounded-2xl border bg-white p-5" do |form| %><%= form.collection_select :classroom_id, @classrooms, :id, :name, { prompt: "Choose a class", selected: @classroom&.id }, class: "form-input flex-1" %><%= form.submit "Configure class", class: "primary-button" %><% end %>

<% if @classroom %><section class="mt-6 rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold"><%= @classroom.name %> controls</h2><%= form_with url: assessment_settings_path, class: "mt-5 space-y-6" do |form| %><%= hidden_field_tag :setting_type, "classroom" %><%= hidden_field_tag :classroom_id, @classroom.id %><div><%= label_tag :result_entry_term_id, "Locked result-entry term", class: "field-label" %><%= select_tag :result_entry_term_id, options_from_collection_for_select(@classroom.academic_year.terms.order(:position), :id, :name, @classroom.result_entry_term_id), include_blank: "Teachers cannot enter results", class: "form-input" %><p class="mt-2 text-xs text-slate-500">Teachers cannot change this term from the result-entry screen.</p></div><div><h3 class="font-bold">Report-card subject order</h3><div class="mt-3 grid gap-3 sm:grid-cols-2"><% @subjects.each do |subject| %><label class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 p-3 text-sm"><span><%= subject.name %></span><%= number_field_tag "subject_positions[#{subject.id}]", @subject_positions[subject.id]&.position, min: 1, class: "w-24 rounded-lg border px-3 py-2", placeholder: "Order" %></label><% end %></div></div><%= form.submit "Save class controls", class: "primary-button" %><% end %></section><% end %>

<div class="mt-8 grid gap-8 lg:grid-cols-2"><section class="rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold"><%= @classroom ? "#{@classroom.name} assessment workflow" : "School default assessment workflow" %></h2><div class="mt-4 divide-y"><% @components.each do |item| %><p class="flex justify-between py-3"><span><%= item.position %>. <%= item.title %></span><strong><%= item.maximum_points %></strong></p><% end %></div><%= form_with url: assessment_settings_path, scope: :assessment_component, class: "mt-6 grid gap-3" do |form| %><%= hidden_field_tag :setting_type, "component" %><%= form.hidden_field :classroom_id, value: @classroom&.id %><%= form.text_field :title, placeholder: "Component name", class: "form-input" %><%= form.number_field :maximum_points, placeholder: "Maximum", class: "form-input" %><%= form.select :kind, Assessment.kinds.keys.map { |kind| [kind.humanize, kind] }, {}, class: "form-input" %><%= form.number_field :position, placeholder: "Position", class: "form-input" %><%= form.submit "Add component", class: "primary-button" %><% end %></section><section class="rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Grade bands</h2><div class="mt-4 divide-y"><% @scales.each do |scale| %><p class="flex justify-between py-3"><span><strong><%= scale.letter %></strong> · <%= scale.remark %></span><span><%= scale.minimum_percentage %>%+</span></p><% end %></div><%= form_with url: assessment_settings_path, scope: :grading_scale, class: "mt-6 grid gap-3" do |form| %><%= hidden_field_tag :setting_type, "scale" %><%= form.text_field :letter, placeholder: "Grade (A)", class: "form-input" %><%= form.number_field :minimum_percentage, placeholder: "Minimum percentage", class: "form-input" %><%= form.text_field :remark, placeholder: "Remark", class: "form-input" %><%= form.submit "Add grade band", class: "primary-button" %><% end %></section></div>
