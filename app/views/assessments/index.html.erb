<% content_for :title, "Assessment workflow · SchoolOS" %><h1 class="text-3xl font-bold">Assessment workflow</h1><div class="mt-8 overflow-x-auto rounded-2xl border bg-white"><table class="w-full text-left text-sm"><thead class="bg-slate-100"><tr><th class="p-4">Assessment</th><th class="p-4">Class / Subject</th><th class="p-4">Status</th><th class="p-4"></th></tr></thead><tbody class="divide-y"><% @records.each do |item| %><tr><td class="p-4 font-semibold"><%= item.title %></td><td class="p-4"><%= item.course_section.classroom.name %> · <%= item.course_section.subject.name %></td><td class="p-4"><%= item.status.humanize %></td><td class="p-4 text-right"><%= button_to "Advance", advance_assessment_path(item), method: :patch, class: "text-sm font-semibold text-indigo-700" %></td></tr><% end %></tbody></table></div>
