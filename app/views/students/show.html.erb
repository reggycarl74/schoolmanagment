<% content_for :title, "#{@student.full_name} · SchoolOS" %><div class="flex justify-between"><div><%= link_to "← Students", students_path, class: "text-sm text-indigo-700" %><h1 class="mt-3 text-3xl font-bold"><%= @student.full_name %></h1><p class="text-slate-500"><%= @student.admission_number %></p></div><% if current_user.administrator? %><%= link_to "Edit profile", edit_student_path(@student), class: "primary-button h-fit" %><% end %></div><div class="mt-8 grid gap-6 lg:grid-cols-3"><section class="rounded-2xl border bg-white p-6"><h2 class="font-bold">Personal details</h2><dl class="mt-4 space-y-3 text-sm"><div><dt class="text-slate-400">Date of birth</dt><dd><%= @student.date_of_birth.to_fs(:long) %></dd></div><div><dt class="text-slate-400">Status</dt><dd><%= @student.status.humanize %></dd></div><div><dt class="text-slate-400">Medical notes</dt><dd><%= @student.medical_notes.presence || "None" %></dd></div></dl></section><section class="rounded-2xl border bg-white p-6"><h2 class="font-bold">Enrollment history</h2><ul class="mt-4 space-y-3"><% @student.enrollments.includes(:classroom).each do |entry| %><li><strong><%= entry.classroom.name %></strong><p class="text-xs text-slate-500"><%= entry.enrolled_on %> · <%= entry.status.humanize %></p></li><% end %></ul></section><section class="rounded-2xl border bg-white p-6"><h2 class="font-bold">Guardians</h2><ul class="mt-4 space-y-3"><% @student.guardians.each do |guardian| %><li><strong><%= guardian.full_name %></strong><p class="text-xs text-slate-500"><%= guardian.phone %></p></li><% end %></ul></section></div><div class="mt-6 flex gap-3"><%= link_to "Assessments", assessments_student_path(@student), class: "primary-button" %><%= link_to "Report card", report_card_path(@student), class: "rounded-xl bg-slate-200 px-5 py-3 font-semibold" %></div>
