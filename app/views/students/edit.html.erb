<% content_for :title, "Edit student · SchoolOS" %><%= render "shared/form_header", title: "Edit student", back_path: student_path(@student) %><%= form_with model: @student, class: "mx-auto max-w-3xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: @student %><%= f.text_field :admission_number, class: "form-input" %><div class="grid grid-cols-2 gap-4"><%= f.text_field :first_name, class: "form-input" %><%= f.text_field :last_name, class: "form-input" %></div><%= f.date_field :date_of_birth, class: "form-input" %><%= f.select :gender, Student.genders.keys.map { |g| [g.humanize, g] }, {}, class: "form-input" %><%= f.select :status, Student.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-input" %><%= f.text_area :medical_notes, rows: 4, class: "form-input" %><%= f.submit "Update profile", class: "primary-button" %><% end %>
