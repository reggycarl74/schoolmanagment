<% content_for :title, "#{@student.full_name} assessments · SchoolOS" %>
<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"><div><%= link_to "← Students", students_path, class: "text-sm font-medium text-slate-500 hover:text-indigo-700" %><h1 class="mt-3 text-3xl font-bold text-slate-900"><%= @student.full_name %></h1><p class="mt-1 text-sm text-slate-500"><%= @student.admission_number %> · Assessment transcript</p></div><%= link_to "View report card", report_card_path(@student), class: "primary-button" %></div>
<% if current_user.administrator? || current_user.registrar? %><%= form_with url: student_documents_path, multipart: true, class: "mt-6 flex items-end gap-3 rounded-xl border bg-white p-4" do |form| %><%= hidden_field_tag :student_id, @student.id %><div class="flex-1"><%= form.label :documents, "Student documents", class: "field-label" %><%= form.file_field :documents, multiple: true, class: "form-input" %></div><%= form.submit "Upload", class: "primary-button" %><% end %><% end %>
<div class="mt-8 overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm"><table class="w-full min-w-[850px] text-left text-sm"><thead class="bg-slate-50 text-slate-600"><tr><th class="p-4">Assessment</th><th class="p-4">Subject</th><th class="p-4">Class / Term</th><th class="p-4">Score</th><th class="p-4">Percentage</th><th class="p-4"></th></tr></thead><tbody class="divide-y divide-slate-100"><% @grades.each do |grade| %><% assessment = grade.assessment %><tr><td class="p-4 font-medium"><%= assessment.title %><p class="text-xs text-slate-400"><%= assessment.due_on.to_fs(:medium) %></p></td><td class="p-4"><%= assessment.course_section.subject.name %></td><td class="p-4"><%= assessment.course_section.classroom.name %> · <%= assessment.course_section.term.name %></td><td class="p-4 font-semibold"><%= grade.points %> / <%= assessment.maximum_points %></td><td class="p-4"><%= number_to_percentage((grade.points.to_d / assessment.maximum_points * 100), precision: 1) %></td><td class="p-4 text-right"><% if current_user.administrator? || current_user.teacher? || current_user.registrar? %><%= link_to "Edit", edit_grade_path(grade), class: "font-semibold text-indigo-700 hover:text-indigo-900" %><% end %></td></tr><% end %></tbody></table><% if @grades.empty? %><p class="p-10 text-center text-slate-500">No assessment results have been entered for this student.</p><% end %></div>
<% if @student.documents.attached? %><section class="mt-6 rounded-2xl border bg-white p-6"><h2 class="font-bold">Documents</h2><ul class="mt-3 space-y-2"><% @student.documents.each do |document| %><li><%= link_to document.filename, rails_blob_path(document, disposition: "attachment"), class: "text-indigo-700" %></li><% end %></ul></section><% end %>
