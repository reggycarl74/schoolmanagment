<% content_for :title, "Exam results · SchoolOS" %>
<%= render "shared/section_header", title: "Exam results", subtitle: "Student assessment scores", button_text: "Enter result", button_path: new_exam_result_path %>
<div class="mt-8 overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm"><table class="w-full text-left text-sm"><thead class="bg-slate-50 text-slate-600"><tr><th class="p-4">Student</th><th class="p-4">Exam</th><th class="p-4">Class / Subject</th><th class="p-4">Score</th><th class="p-4">Date</th></tr></thead><tbody class="divide-y divide-slate-100"><% @grades.each do |grade| %><tr><td class="p-4 font-medium"><%= grade.enrollment.student.full_name %></td><td class="p-4"><%= grade.assessment.title %></td><td class="p-4"><%= grade.assessment.course_section.classroom.name %> · <%= grade.assessment.course_section.subject.name %></td><td class="p-4 font-semibold"><%= grade.points %> / <%= grade.assessment.maximum_points %></td><td class="p-4"><%= grade.assessment.due_on.to_fs(:long) %></td></tr><% end %></tbody></table><% if @grades.empty? %><p class="p-10 text-center text-slate-500">No exam results yet.</p><% end %></div>
