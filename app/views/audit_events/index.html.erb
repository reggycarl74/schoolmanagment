<% content_for :title, "Audit history · SchoolOS" %><h1 class="text-3xl font-bold">Audit history</h1><div class="mt-8 overflow-hidden rounded-2xl border bg-white"><ul class="divide-y"><% @events.each do |event| %><li class="p-4"><strong><%= event.user&.full_name || "System" %></strong> <%= event.action %> <%= event.auditable_type %> #<%= event.auditable_id %><span class="float-right text-sm text-slate-400"><%= event.created_at.to_fs(:long) %></span></li><% end %></ul></div>
