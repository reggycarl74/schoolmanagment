<% content_for :title, "Edit profile · SchoolOS" %>
<div class="mx-auto max-w-3xl"><div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg"><div class="bg-gradient-to-r from-indigo-700 via-violet-700 to-fuchsia-600 px-6 py-8 text-white sm:px-8"><div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-white/15 text-2xl font-black backdrop-blur"><%= @user.first_name.first %><%= @user.last_name.first %></div><p class="mt-5 text-xs font-bold uppercase tracking-[0.2em] text-indigo-200"><%= @user.role.humanize %> account</p><h1 class="mt-2 text-3xl font-bold">Edit your profile</h1><p class="mt-2 text-sm text-indigo-100">Update your personal details or securely choose a new password.</p></div>
<%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-8 p-6 sm:p-8", data: { controller: "password-visibility" } do |form| %>
  <%= render "shared/form_errors", object: @user %>
  <section><div class="flex items-center gap-3"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-sky-100">👤</span><div><h2 class="font-bold text-slate-900">Personal information</h2><p class="text-xs text-slate-500">The name shown throughout SchoolOS.</p></div></div><div class="mt-5 grid gap-5 sm:grid-cols-2"><div><%= form.label :first_name, class: "field-label" %><%= form.text_field :first_name, required: true, autocomplete: "given-name", class: "form-input" %></div><div><%= form.label :last_name, class: "field-label" %><%= form.text_field :last_name, required: true, autocomplete: "family-name", class: "form-input" %></div><div class="sm:col-span-2"><%= form.label :email, class: "field-label" %><%= form.email_field :email, required: true, autocomplete: "email", class: "form-input" %></div></div></section>
  <section class="border-t border-slate-200 pt-7"><div class="flex flex-wrap items-center justify-between gap-3"><div class="flex items-center gap-3"><span class="flex h-9 w-9 items-center justify-center rounded-xl bg-violet-100">🔐</span><div><h2 class="font-bold text-slate-900">Change password</h2><p class="text-xs text-slate-500">Leave these fields blank to keep your current password.</p></div></div><button type="button" class="rounded-xl bg-violet-50 px-3 py-2 text-xs font-bold text-violet-700 hover:bg-violet-100" data-action="password-visibility#toggle" data-password-visibility-target="label">Show passwords</button></div><div class="mt-5 space-y-5"><div><%= label_tag :current_password, "Current password", class: "field-label" %><%= password_field_tag :current_password, nil, autocomplete: "current-password", class: "form-input", data: { password_visibility_target: "field" } %></div><div class="grid gap-5 sm:grid-cols-2"><div><%= form.label :password, "New password", class: "field-label" %><%= form.password_field :password, autocomplete: "new-password", class: "form-input", data: { password_visibility_target: "field" } %></div><div><%= form.label :password_confirmation, "Confirm new password", class: "field-label" %><%= form.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", data: { password_visibility_target: "field" } %></div></div></div></section>
  <div class="flex flex-col-reverse gap-3 border-t border-slate-100 pt-6 sm:flex-row sm:justify-end"><%= link_to "Cancel", root_path, class: "rounded-xl px-5 py-3 text-center text-sm font-bold text-slate-600 hover:bg-slate-100" %><%= form.submit "Save profile", class: "primary-button" %></div>
<% end %></div></div>
