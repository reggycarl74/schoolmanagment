<% content_for :title, "Attendance analytics · SchoolOS" %>
<h1 class="text-3xl font-bold">Attendance analytics</h1><p class="mt-2 text-slate-500">Spot attendance patterns and students who may need support.</p>
<%= form_with url: attendance_analytics_path, method: :get, class: "mt-6 grid gap-4 rounded-2xl border bg-white p-5 md:grid-cols-4 md:items-end" do |form| %><div><%= form.label :classroom_id, "Class", class: "field-label" %><%= form.collection_select :classroom_id, @classrooms, :id, :name, { include_blank: "All accessible classes", selected: @classroom&.id }, class: "form-input" %></div><div><%= form.label :from, class: "field-label" %><%= form.date_field :from, value: @from, class: "form-input" %></div><div><%= form.label :to, class: "field-label" %><%= form.date_field :to, value: @to, class: "form-input" %></div><%= form.submit "Apply", class: "primary-button" %><% end %>
<div class="mt-6 grid gap-4 sm:grid-cols-4"><% AttendanceRecord.statuses.each_key do |status| %><div class="rounded-2xl border bg-white p-5"><p class="text-sm capitalize text-slate-500"><%= status %></p><p class="mt-2 text-3xl font-bold"><%= @summary[status] || 0 %></p></div><% end %></div>
<div class="mt-6 rounded-2xl border bg-white p-6"><h2 class="text-xl font-bold">Frequent absences</h2><p class="mt-1 text-sm text-slate-500">Three or more absences during this period.</p><div class="mt-4 divide-y"><% @frequent_absences.each do |enrollment_id, count| %><div class="flex justify-between py-3"><%= link_to @enrollments[enrollment_id].student.full_name, student_path(@enrollments[enrollment_id].student), class: "font-semibold text-indigo-700" %><span><%= count %> absences</span></div><% end %><% if @frequent_absences.empty? %><p class="py-6 text-slate-500">No students crossed the alert threshold.</p><% end %></div></div>
