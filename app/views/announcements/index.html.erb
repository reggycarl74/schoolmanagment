<% content_for :title, "Announcements · SchoolOS" %><%= render "shared/section_header", title: "Announcements", subtitle: "School news and notices", button_text: "New announcement", button_path: (new_announcement_path if current_user.administrator?) %><div class="mt-8 grid gap-5"><% @announcements.each do |item| %><article class="rounded-2xl border bg-white p-6"><div class="flex justify-between"><h2 class="text-xl font-bold"><%= item.title %></h2><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs text-indigo-700"><%= item.audience.humanize %></span></div><p class="mt-4 whitespace-pre-line text-slate-700"><%= item.body %></p><p class="mt-4 text-xs text-slate-400"><%= item.author.full_name %> · <%= item.published_at.to_fs(:long) %></p></article><% end %></div>
