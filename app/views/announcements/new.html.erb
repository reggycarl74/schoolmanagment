<% content_for :title, "New announcement · SchoolOS" %><%= render "shared/form_header", title: "New announcement", back_path: announcements_path %><%= form_with model: @announcement, class: "mx-auto max-w-3xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: @announcement %><%= f.text_field :title, placeholder: "Title", class: "form-input" %><%= f.text_area :body, rows: 8, placeholder: "Announcement", class: "form-input" %><%= f.select :audience, Announcement.audiences.keys.map { |a| [a.humanize, a] }, {}, class: "form-input" %><%= f.datetime_local_field :published_at, class: "form-input" %><%= f.submit "Publish", class: "primary-button" %><% end %>
