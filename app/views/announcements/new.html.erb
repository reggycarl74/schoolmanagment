<% content_for :title, "New announcement · SchoolOS" %><%= render "shared/form_header", title: "New announcement", back_path: announcements_path %><%= form_with model: @announcement, class: "mx-auto max-w-3xl space-y-5 rounded-2xl border bg-white p-8" do |form| %><%= render "shared/form_errors", object: @announcement %><%= form.text_field :title, placeholder: "Title", class: "form-input" %><%= form.text_area :body, rows: 8, placeholder: "Announcement", class: "form-input" %><%= form.select :audience, Announcement.audiences.keys.map { |audience| [audience.humanize, audience] }, {}, class: "form-input" %><%= form.datetime_local_field :published_at, class: "form-input" %><fieldset class="rounded-2xl bg-indigo-50 p-4"><legend class="field-label">Send announcement by</legend><div class="flex gap-6"><label class="flex items-center gap-2 font-semibold"><%= form.check_box :send_email %> Email</label><label class="flex items-center gap-2 font-semibold"><%= form.check_box :send_sms %> SMS</label></div></fieldset><%= form.submit "Publish and send", class: "primary-button" %><% end %>
