<div class="flex flex-col gap-5 rounded-3xl bg-gradient-to-r from-indigo-700 via-violet-700 to-fuchsia-600 px-6 py-7 text-white shadow-lg shadow-indigo-100 sm:flex-row sm:items-end sm:justify-between sm:px-8">
  <div><p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-200"><%= subtitle %></p><h1 class="mt-2 text-3xl font-bold sm:text-4xl"><%= title %></h1></div>
  <% if button_path.present? %><%= link_to button_text, button_path, class: "inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-bold text-indigo-700 shadow-lg transition hover:-translate-y-0.5 hover:bg-indigo-50" %><% end %>
</div>
