<div class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"><% if records.any? %><ul class="divide-y divide-slate-100"><% records.each do |record| %><li class="flex justify-between px-6 py-4"><span class="font-medium"><%= record.respond_to?(:full_name) ? record.full_name : record.name %></span><span class="text-sm text-slate-400">#<%= record.id %></span></li><% end %></ul><% else %><p class="p-10 text-center text-slate-500">No records yet.</p><% end %></div>
