<%= form_with url: search_path, method: :get, class: "relative", role: "search" do |form| %><span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">⌕</span><%= form.search_field :q, value: params[:q], placeholder: "Search SchoolOS...", autocomplete: "off", class: "h-11 w-full rounded-xl border border-slate-200 bg-slate-50 pl-9 pr-4 text-sm font-medium text-slate-700 outline-none transition focus:border-indigo-400 focus:bg-white focus:ring-4 focus:ring-indigo-100 xl:w-56" %><% end %>
