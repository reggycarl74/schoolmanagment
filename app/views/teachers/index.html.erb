<% content_for :title, "Teachers · SchoolOS" %>
<%= render "shared/section_header", title: "Teachers", subtitle: "Teaching staff and assigned classes", button_text: "Add teacher", button_path: (new_teacher_path if current_user.administrator?) %>
<div class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"><% if @records.any? %><ul class="divide-y divide-slate-100"><% @records.each do |teacher| %><li class="px-6 py-5"><div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"><div><p class="font-semibold text-slate-900"><%= teacher.full_name %></p><p class="text-sm text-slate-500"><%= teacher.employee_number %> · <%= teacher.email %></p></div><div class="flex max-w-xl flex-wrap gap-2"><% teacher.assigned_classrooms.distinct.each do |classroom| %><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700"><%= classroom.name %></span><% end %><% if teacher.teaching_assignments.empty? %><span class="text-sm text-slate-400">No assigned classes</span><% end %></div></div></li><% end %></ul><% else %><p class="p-10 text-center text-slate-500">No teachers yet.</p><% end %></div>
<% if current_user.administrator? %><div class="mt-5 text-right"><%= link_to "Manage class assignments →", teaching_assignments_path, class: "text-sm font-semibold text-indigo-700" %></div><% end %>
