<% content_for :title, "Attendance register · SchoolOS" %><h1 class="text-3xl font-bold">Attendance register</h1><%= form_with url: attendance_register_path, method: :get, class: "mt-6 flex flex-wrap items-end gap-4 rounded-2xl border bg-white p-5" do |f| %><div><%= f.label :classroom_id, "Class", class: "field-label" %><%= f.collection_select :classroom_id, @classrooms, :id, :name, { prompt: "Select class", selected: params[:classroom_id] }, class: "form-input" %></div><div><%= f.label :date, class: "field-label" %><%= f.date_field :date, value: @date, class: "form-input" %></div><%= f.submit "Load register", class: "primary-button" %><% if @classroom %><%= link_to "Export CSV", attendance_register_path(classroom_id: @classroom.id, date: @date, format: :csv), class: "rounded-xl bg-emerald-50 px-5 py-3 text-sm font-bold text-emerald-700" %><% end %><% end %><% if @classroom %><%= form_with url: attendance_register_path(classroom_id: @classroom.id, date: @date), method: :post do %><div class="mt-6 overflow-x-auto rounded-2xl border bg-white"><table class="w-full min-w-[1050px] text-left"><thead class="bg-slate-100"><tr><th class="p-4">Student</th><th class="p-4">Status</th><th class="p-4">Arrival</th><th class="p-4">Departure</th><th class="p-4">Absence reason</th><th class="p-4">Notes</th></tr></thead><tbody class="divide-y"><% @enrollments.each do |entry| %><% record = @records[entry.id] %><tr><td class="p-4 font-medium"><%= entry.student.full_name %></td><td class="p-3"><%= select_tag "attendance[#{entry.id}][status]", options_for_select(AttendanceRecord.statuses.keys.map { |s| [s.humanize, s] }, record&.status || "present"), class: "form-input" %></td><td class="p-3"><%= time_field_tag "attendance[#{entry.id}][arrived_at]", record&.arrived_at&.strftime("%H:%M"), class: "form-input" %></td><td class="p-3"><%= time_field_tag "attendance[#{entry.id}][departed_at]", record&.departed_at&.strftime("%H:%M"), class: "form-input" %></td><td class="p-3"><%= text_field_tag "attendance[#{entry.id}][absence_reason]", record&.absence_reason, placeholder: "Illness, appointment…", class: "form-input" %></td><td class="p-3"><%= text_field_tag "attendance[#{entry.id}][notes]", record&.notes, class: "form-input" %></td></tr><% end %></tbody></table></div><div class="mt-4 text-right"><%= submit_tag "Save attendance", class: "primary-button" %></div><% end %><% end %>
