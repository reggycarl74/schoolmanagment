<% content_for :title, "Report card · SchoolOS" %>
<div class="print:hidden"><%= link_to "← Student assessments", assessments_student_path(@student), class: "text-sm font-semibold text-indigo-700" %></div>
<div class="mx-auto mt-5 max-w-4xl rounded-2xl border bg-white p-8 shadow-sm print:border-0 print:shadow-none">
  <div class="text-center"><% if current_school.logo.attached? %><%= image_tag current_school.logo, class: "mx-auto mb-4 h-24 w-24 object-contain", alt: "#{current_school.name} logo" %><% end %><h1 class="text-3xl font-bold"><%= current_school.name %></h1><% if current_school.address.present? %><p class="mt-1 text-sm text-slate-500"><%= current_school.address %></p><% end %><p class="mt-2 text-slate-500">Term report card</p><h2 class="mt-5 text-xl font-semibold"><%= @student.full_name %> · <%= @term&.name %></h2></div>
  <table class="mt-8 w-full text-left"><thead class="bg-slate-100"><tr><th class="p-3">Subject</th><th class="p-3">Score</th><th class="p-3">Percentage</th><th class="p-3">Grade</th><th class="p-3">Remark</th></tr></thead><tbody class="divide-y"><% @subject_results.each do |row| %><tr><td class="p-3 font-medium"><%= row[:subject].name %></td><td class="p-3"><%= row[:earned] %> / <%= row[:possible] %></td><td class="p-3"><%= number_to_percentage(row[:percentage], precision: 1) %></td><td class="p-3 font-bold"><%= row[:scale]&.letter || "—" %></td><td class="p-3"><%= row[:scale]&.remark %></td></tr><% end %></tbody></table>
  <div class="mt-8 grid grid-cols-2 gap-4 rounded-xl bg-slate-50 p-5"><% AttendanceRecord.statuses.each_key do |status| %><p><strong><%= status.humanize %>:</strong> <%= @attendance[status] || 0 %></p><% end %></div>
  <section class="mt-8"><h3 class="text-lg font-bold">Teacher comments</h3><% @comments.each do |comment| %><div class="mt-3 rounded-xl border p-4"><p class="text-xs font-semibold uppercase text-slate-500"><%= comment.kind.humanize %> · <%= comment.approved? ? "Approved" : "Awaiting approval" %></p><p class="mt-2"><%= comment.body %></p><p class="mt-2 text-xs text-slate-500"><%= comment.author.full_name %></p><% if current_user.administrator? && !comment.approved? %><%= button_to "Approve", report_card_comment_path(comment, approved: true), method: :patch, class: "mt-3 text-sm font-semibold text-emerald-700" %><% end %></div><% end %></section>
  <% if @term&.reopening_date %><div class="mt-8 rounded-xl border-2 border-indigo-200 bg-indigo-50 p-5 text-center"><p class="text-sm font-semibold uppercase tracking-wide text-indigo-700">School reopens</p><p class="mt-1 text-xl font-bold text-indigo-950"><%= @term.reopening_date.to_fs(:long) %></p></div><% end %>
  <% if @term && (current_user.teacher? || current_user.administrator? || current_user.registrar?) %>
    <%= form_with model: ReportCardComment.new, class: "mt-8 overflow-hidden rounded-2xl border border-indigo-200 bg-white shadow-sm print:hidden", data: { controller: "remark-picker" } do |form| %>
      <%= form.hidden_field :student_id, value: @student.id %><%= form.hidden_field :term_id, value: @term.id %>
      <div class="flex items-center justify-between bg-gradient-to-r from-indigo-700 to-violet-700 px-6 py-5 text-white"><div><p class="text-xs font-bold uppercase tracking-widest text-indigo-200">Teacher workspace</p><h3 class="mt-1 text-xl font-bold">Add or update a report remark</h3></div><span class="rounded-full bg-white/15 px-3 py-1 text-xs font-semibold">Not printed</span></div>
      <div class="space-y-5 p-6"><div class="rounded-2xl border border-indigo-100 bg-indigo-50 p-4"><div class="flex items-center justify-between"><%= label_tag :remark_template, "1. Choose a saved remark", class: "field-label !mb-0" %><%= link_to "Manage library", report_card_remark_templates_path, class: "text-xs font-bold text-indigo-700" %></div><%= select_tag :remark_template, options_for_select(@remark_templates.map { |template| [template.title, template.id, { data: { body: template.body, kind: template.kind } }] }), include_blank: "Choose a remark or start from scratch", class: "form-input mt-2 bg-white", data: { remark_picker_target: "select", action: "change->remark-picker#choose" } %></div><div class="grid gap-5 md:grid-cols-4"><div><%= form.label :kind, "2. Category", class: "field-label" %><%= form.select :kind, @comment_kinds.map { |kind| [kind.humanize, kind] }, {}, class: "form-input", data: { remark_picker_target: "kind" } %></div><div class="md:col-span-3"><%= form.label :body, "3. Personalize for #{@student.first_name}", class: "field-label" %><%= form.text_area :body, required: true, rows: 4, placeholder: "Select a saved remark above or write a personal comment...", class: "form-input resize-y", data: { remark_picker_target: "body" } %><p class="mt-2 flex items-center gap-2 text-xs text-slate-500"><span class="flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100 font-bold text-emerald-700">✓</span>The saved template is only a starting point—your changes apply to this student only.</p></div></div><div class="flex justify-end border-t border-slate-100 pt-5"><%= form.submit "Save report-card remark", class: "primary-button" %></div></div>
    <% end %>
  <% end %>
  <button onclick="window.print()" class="primary-button mt-6 print:hidden">Print / Save PDF</button>
</div>
