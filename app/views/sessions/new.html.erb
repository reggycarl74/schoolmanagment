<% content_for :title, "Sign in · SchoolOS" %>
<div class="mx-auto mt-10 max-w-md"><div class="mb-8 text-center"><p class="text-2xl font-bold text-indigo-700">SchoolOS</p><h1 class="mt-5 text-3xl font-bold text-slate-900">Welcome back</h1><p class="mt-2 text-sm text-slate-500">Sign in with your school account.</p></div><%= form_with url: session_path, scope: :session, class: "space-y-5 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm" do |form| %><div><%= form.label :school_code, class: "field-label" %><%= form.text_field :school_code, required: true, autofocus: true, autocomplete: "organization", placeholder: "DEMO", class: "form-input uppercase" %></div><div><%= form.label :email, class: "field-label" %><%= form.email_field :email, required: true, autocomplete: "username", placeholder: "teacher@example.test", class: "form-input" %></div><div data-controller="password-visibility"><div class="flex items-center justify-between"><%= form.label :password, class: "field-label" %><button type="button" class="text-xs font-bold text-indigo-700" data-action="password-visibility#toggle" data-password-visibility-target="label">Show passwords</button></div><%= form.password_field :password, required: true, autocomplete: "current-password", class: "form-input", data: { password_visibility_target: "field" } %><div class="mt-2 text-right"><%= link_to "Forgot password?", new_password_path, class: "text-sm font-semibold text-indigo-700 hover:text-indigo-900" %></div></div><%= form.submit "Sign in", class: "primary-button w-full" %><% end %></div>
