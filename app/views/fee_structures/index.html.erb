<% content_for :title, "Fee structures · SchoolOS" %><%= render "shared/section_header", title: "Fee structures", subtitle: "School charges by academic year", button_text: "Create fee structure", button_path: new_fee_structure_path %>
<div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3"><% @fee_structures.each do |fee| %><article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><div class="h-1.5 bg-gradient-to-r from-amber-400 to-orange-500"></div><div class="p-6"><div class="flex items-start justify-between gap-4"><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700"><%= fee.academic_year.name %></span><span class="text-xs font-semibold text-slate-400">Due <%= fee.due_on.to_fs(:medium) %></span></div><h2 class="mt-5 text-xl font-bold"><%= fee.name %></h2><p class="mt-2 text-3xl font-black text-slate-900"><%= number_to_currency(fee.amount) %></p><div class="mt-5 grid grid-cols-2 gap-3 rounded-2xl bg-slate-50 p-4 text-center"><div><p class="text-2xl font-bold text-indigo-700"><%= fee.invoices.size %></p><p class="text-xs text-slate-500">Invoices</p></div><div><p class="text-2xl font-bold text-emerald-700"><%= number_to_currency(fee.invoices.sum(&:amount)) %></p><p class="text-xs text-slate-500">Assigned</p></div></div><%= link_to "Create student invoice →", new_invoice_path, class: "mt-5 inline-block text-sm font-bold text-indigo-700" %></div></article><% end %></div><% if @fee_structures.empty? %><div class="mt-8 rounded-3xl border-2 border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-4xl">🧾</div><h2 class="mt-4 text-xl font-bold">No fee structures yet</h2><p class="mt-2 text-sm text-slate-500">Create a reusable fee before invoicing students.</p></div><% end %>
