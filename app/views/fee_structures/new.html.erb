<% content_for :title, "New fee · SchoolOS" %><%= render "shared/form_header", title: "Create fee structure", back_path: invoices_path %><%= form_with model: @fee_structure, class: "mx-auto max-w-2xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: @fee_structure %><%= f.collection_select :academic_year_id, @academic_years, :id, :name, { prompt: "Academic year" }, class: "form-input" %><%= f.text_field :name, placeholder: "Fee name", class: "form-input" %><%= f.number_field :amount, step: 0.01, placeholder: "Amount", class: "form-input" %><%= f.date_field :due_on, class: "form-input" %><%= f.submit "Save fee", class: "primary-button" %><% end %>
