<% content_for :title, "Timetable · SchoolOS" %>
<%= render "shared/section_header", title: "Timetable", subtitle: "Weekly class schedule", button_text: "Add period", button_path: (new_timetable_entry_path if current_user.administrator?) %>
<% days = TimetableEntry.weekdays.keys %><% periods = @entries.map(&:period).uniq.sort %>
<div class="mt-8 overflow-x-auto rounded-2xl border bg-white shadow-sm"><table class="min-w-[1000px] w-full table-fixed text-sm"><thead class="bg-slate-900 text-white"><tr><th class="w-24 p-4 text-left">Period</th><% days.each do |day| %><th class="p-4 text-left"><%= day.humanize %></th><% end %></tr></thead><tbody class="divide-y"><% periods.each do |period| %><tr class="align-top"><th class="bg-slate-50 p-4 text-left text-lg"><%= period %></th><% days.each do |day| %><td class="border-l p-3"><% @entries.select { |entry| entry.period == period && entry.weekday == day }.each do |entry| %><div class="mb-2 rounded-xl border border-indigo-100 bg-indigo-50 p-3"><p class="font-bold text-indigo-900"><%= entry.course_section.subject.name %></p><p class="mt-1"><%= entry.course_section.classroom.name %> · <%= entry.teacher.full_name %></p><p class="mt-1 text-xs text-slate-500"><%= entry.starts_at.strftime("%H:%M") %>–<%= entry.ends_at.strftime("%H:%M") %><%= " · #{entry.room}" if entry.room.present? %></p><% if current_user.administrator? %><%= button_to "Remove", timetable_entry_path(entry), method: :delete, class: "mt-2 text-xs font-semibold text-red-700", data: { turbo_confirm: "Remove this period?" } %><% end %></div><% end %></td><% end %></tr><% end %></tbody></table><% if periods.empty? %><p class="p-10 text-center text-slate-500">No timetable periods have been added.</p><% end %></div>
