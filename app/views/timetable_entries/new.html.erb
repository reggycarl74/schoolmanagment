<% content_for :title, "Add timetable period · SchoolOS" %><%= render "shared/form_header", title: "Add timetable period", back_path: timetable_entries_path %><%= form_with model: @entry, class: "mx-auto max-w-3xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: @entry %><%= f.collection_select :course_section_id, @courses, :id, ->(c) { "#{c.classroom.name} · #{c.subject.name} · #{c.term.name}" }, { prompt: "Select course" }, class: "form-input" %><%= f.collection_select :teacher_id, @teachers, :id, :full_name, { prompt: "Select teacher" }, class: "form-input" %><%= f.select :weekday, TimetableEntry.weekdays.keys.map { |d| [d.humanize, d] }, {}, class: "form-input" %><%= f.number_field :period, placeholder: "Period number", class: "form-input" %><div class="grid grid-cols-2 gap-4"><%= f.time_field :starts_at, class: "form-input" %><%= f.time_field :ends_at, class: "form-input" %></div><%= f.text_field :room, placeholder: "Room", class: "form-input" %><%= f.submit "Save period", class: "primary-button" %><% end %>
