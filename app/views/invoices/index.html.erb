<% content_for :title, "Billing · SchoolOS" %><%= render "shared/section_header", title: "Billing", subtitle: "Invoices, balances, and payments", button_text: "New invoice", button_path: (new_invoice_path if current_user.administrator? || current_user.accountant?) %><div class="mt-8 overflow-x-auto rounded-2xl border bg-white"><table class="w-full text-left text-sm"><thead class="bg-slate-100"><tr><th class="p-4">Student</th><th class="p-4">Fee</th><th class="p-4">Amount</th><th class="p-4">Paid</th><th class="p-4">Balance</th><th class="p-4">Status</th></tr></thead><tbody class="divide-y"><% @invoices.each do |invoice| %><tr><td class="p-4 font-semibold"><%= invoice.student.full_name %></td><td class="p-4"><%= invoice.fee_structure.name %></td><td class="p-4"><%= number_to_currency(invoice.amount) %></td><td class="p-4"><%= number_to_currency(invoice.paid_amount) %></td><td class="p-4"><%= number_to_currency(invoice.balance) %></td><td class="p-4"><%= invoice.status.humanize %></td></tr><% if (current_user.administrator? || current_user.accountant?) && invoice.balance.positive? %><tr class="bg-slate-50"><td colspan="6" class="p-3"><%= form_with url: invoice_payments_path(invoice), scope: :payment, class: "flex flex-wrap items-end gap-2" do |f| %><%= f.number_field :amount, max: invoice.balance, step: 0.01, placeholder: "Payment amount", class: "form-input max-w-44" %><%= f.date_field :paid_on, value: Date.current, class: "form-input max-w-44" %><%= f.text_field :reference, placeholder: "Reference", class: "form-input max-w-44" %><%= f.select :payment_method, Payment.payment_methods.keys.map { |m| [m.humanize, m] }, {}, class: "form-input max-w-44" %><%= f.submit "Record payment", class: "primary-button" %><% end %></td></tr><% end %><% end %></tbody></table></div>
