<% content_for :title, "Billing · SchoolOS" %>
<%= render "shared/section_header", title: "Billing", subtitle: "Invoices, receipts, balances, and payment plans", button_text: "Generate invoices", button_path: (new_invoice_path if current_user.administrator? || current_user.accountant?) %>

<div class="mt-6 grid gap-4 sm:grid-cols-3">
  <div class="rounded-2xl border bg-white p-5"><p class="text-sm text-slate-500">Invoices</p><p class="mt-2 text-3xl font-black"><%= @invoices.size %></p></div>
  <div class="rounded-2xl border bg-white p-5"><p class="text-sm text-slate-500">Collected</p><p class="mt-2 text-3xl font-black text-emerald-700"><%= money(@total_collected) %></p></div>
  <div class="rounded-2xl border bg-white p-5"><p class="text-sm text-slate-500">Outstanding</p><p class="mt-2 text-3xl font-black text-amber-700"><%= money(@total_outstanding) %></p></div>
</div>

<div class="mt-8 overflow-x-auto rounded-2xl border bg-white shadow-sm"><table class="w-full min-w-[850px] text-left text-sm"><thead class="bg-slate-100"><tr><th class="p-4">Invoice</th><th class="p-4">Student</th><th class="p-4">Fee</th><th class="p-4">Due</th><th class="p-4">Total</th><th class="p-4">Paid</th><th class="p-4">Balance</th><th class="p-4">Status</th></tr></thead><tbody class="divide-y"><% @invoices.each do |invoice| %><tr class="hover:bg-slate-50"><td class="p-4"><%= link_to invoice.number, invoice_path(invoice), class: "font-bold text-indigo-700" %></td><td class="p-4"><%= link_to invoice.student.full_name, student_billing_statement_path(invoice.student), class: "font-semibold text-slate-900 hover:text-indigo-700" %></td><td class="p-4"><%= invoice.fee_structure.name %></td><td class="p-4"><%= invoice.due_on.to_fs(:medium) %></td><td class="p-4"><%= money(invoice.amount) %></td><td class="p-4 text-emerald-700"><%= money(invoice.paid_amount) %></td><td class="p-4 font-bold"><%= money(invoice.balance) %></td><td class="p-4"><span class="rounded-full px-3 py-1 text-xs font-bold <%= invoice.paid? ? 'bg-emerald-100 text-emerald-700' : invoice.overdue? ? 'bg-red-100 text-red-700' : invoice.cancelled? ? 'bg-slate-200 text-slate-600' : 'bg-amber-100 text-amber-700' %>"><%= invoice.status.humanize %></span></td></tr><% end %></tbody></table></div>
