<% content_for :title, "#{@invoice.number} · SchoolOS" %>
<div class="flex flex-col gap-5 rounded-3xl bg-gradient-to-r from-indigo-700 to-violet-700 p-7 text-white sm:flex-row sm:items-end sm:justify-between"><div><p class="text-xs font-bold uppercase tracking-widest text-indigo-200">Invoice</p><h1 class="mt-2 text-3xl font-black"><%= @invoice.number %></h1><p class="mt-2 text-indigo-100"><%= @invoice.student.full_name %> · issued <%= @invoice.issued_on.to_fs(:long) %></p></div><div class="text-left sm:text-right"><p class="text-sm text-indigo-200">Outstanding</p><p class="text-3xl font-black"><%= money(@invoice.balance) %></p></div></div>

<div class="mt-6 grid gap-6 lg:grid-cols-[1.5fr_1fr]">
  <div class="space-y-6">
    <section class="rounded-2xl border bg-white p-6 shadow-sm"><div class="flex items-center justify-between"><h2 class="text-xl font-bold">Line items</h2><span class="text-sm text-slate-500">Due <%= @invoice.due_on.to_fs(:long) %></span></div><div class="mt-4 divide-y"><% @invoice.line_items.each do |item| %><div class="flex items-center justify-between gap-4 py-4"><div><p class="font-semibold"><%= item.description %></p><p class="text-xs text-slate-500"><%= item.category.humanize %> · <%= item.quantity %> × <%= money(item.unit_amount) %></p></div><div class="flex items-center gap-3"><strong><%= money(item.total) %></strong><% if current_user.administrator? || current_user.accountant? %><%= button_to "×", invoice_invoice_line_item_path(@invoice, item), method: :delete, class: "text-red-600", form: { data: { turbo_confirm: "Remove this charge?" } } %><% end %></div></div><% end %></div>
      <% if current_user.administrator? || current_user.accountant? %><%= form_with url: invoice_invoice_line_items_path(@invoice), scope: :invoice_line_item, class: "mt-5 grid gap-3 rounded-xl bg-slate-50 p-4 sm:grid-cols-4" do |f| %><%= f.text_field :description, placeholder: "Description", required: true, class: "form-input sm:col-span-2" %><%= f.select :category, InvoiceLineItem.categories.keys.map { |x| [x.humanize, x] }, {}, class: "form-input" %><%= f.number_field :quantity, value: 1, min: 0.01, step: 0.01, class: "form-input" %><%= f.number_field :unit_amount, min: 0.01, step: 0.01, placeholder: "Unit amount", required: true, class: "form-input sm:col-span-2" %><%= f.submit "Add charge", class: "primary-button sm:col-span-2" %><% end %><% end %>
    </section>

    <section class="rounded-2xl border bg-white p-6 shadow-sm"><h2 class="text-xl font-bold">Payments and receipts</h2><div class="mt-4 divide-y"><% @invoice.payments.each do |payment| %><div class="flex items-center justify-between gap-4 py-4 <%= 'opacity-50 line-through' if payment.reversed? %>"><div><%= link_to payment.receipt_number, invoice_payment_path(@invoice, payment), class: "font-bold text-indigo-700" %><p class="text-xs text-slate-500"><%= payment.paid_on.to_fs(:long) %> · <%= payment.payment_method.humanize %> · <%= payment.reference %></p></div><strong class="text-emerald-700"><%= money(payment.amount) %></strong></div><% end %><% if @invoice.payments.empty? %><p class="py-5 text-sm text-slate-500">No payments recorded.</p><% end %></div>
      <% if (current_user.administrator? || current_user.accountant?) && @invoice.balance.positive? && !@invoice.cancelled? %><%= form_with url: invoice_payments_path(@invoice), scope: :payment, class: "mt-5 grid gap-3 rounded-xl bg-emerald-50 p-4 sm:grid-cols-2" do |f| %><%= f.number_field :amount, max: @invoice.balance, min: 0.01, step: 0.01, placeholder: "Payment amount", required: true, class: "form-input" %><%= f.date_field :paid_on, value: Date.current, required: true, class: "form-input" %><%= f.text_field :reference, placeholder: "Bank/cash reference", required: true, class: "form-input" %><%= f.select :payment_method, Payment.payment_methods.keys.map { |m| [m.humanize, m] }, {}, class: "form-input" %><%= f.submit "Record payment", class: "primary-button sm:col-span-2" %><% end %><% end %>
    </section>
  </div>

  <aside class="space-y-6">
    <section class="rounded-2xl border bg-white p-6 shadow-sm"><h2 class="font-bold">Account summary</h2><dl class="mt-4 space-y-3 text-sm"><div class="flex justify-between"><dt>Charges</dt><dd><%= money(@invoice.amount) %></dd></div><div class="flex justify-between"><dt>Legacy discount</dt><dd>-<%= money(@invoice.discount) %></dd></div><div class="flex justify-between"><dt>Credits/scholarships</dt><dd>-<%= money(@invoice.credit_adjustments) %></dd></div><div class="flex justify-between"><dt>Additional charges/refunds</dt><dd><%= money(@invoice.debit_adjustments) %></dd></div><div class="flex justify-between"><dt>Payments</dt><dd>-<%= money(@invoice.paid_amount) %></dd></div><div class="flex justify-between border-t pt-3 text-lg font-black"><dt>Balance</dt><dd><%= money(@invoice.balance) %></dd></div></dl><div class="mt-5 grid gap-2"><%= link_to "Student statement", student_billing_statement_path(@invoice.student), class: "rounded-xl bg-indigo-50 px-4 py-3 text-center text-sm font-bold text-indigo-700" %><% if current_user.administrator? || current_user.accountant? %><%= button_to "Send payment reminder", send_reminder_invoice_path(@invoice), class: "w-full rounded-xl bg-amber-50 px-4 py-3 text-sm font-bold text-amber-700" %><% end %><% if current_user.administrator? && @invoice.paid_amount.zero? && !@invoice.cancelled? %><%= button_to "Cancel invoice", cancel_invoice_path(@invoice), method: :patch, class: "w-full rounded-xl bg-red-50 px-4 py-3 text-sm font-bold text-red-700", form: { data: { turbo_confirm: "Cancel this invoice?" } } %><% end %></div></section>

    <section class="rounded-2xl border bg-white p-6 shadow-sm"><h2 class="font-bold">Payment plan</h2><div class="mt-3 space-y-2"><% @invoice.payment_installments.order(:due_on).each do |installment| %><div class="rounded-xl bg-slate-50 p-3 text-sm"><div class="flex justify-between"><strong><%= installment.name %></strong><span><%= money(installment.amount) %></span></div><p class="mt-1 text-xs text-slate-500">Due <%= installment.due_on.to_fs(:long) %> · <%= installment.status.humanize %></p></div><% end %></div><% if current_user.administrator? || current_user.accountant? %><%= form_with url: invoice_payment_installments_path(@invoice), scope: :payment_installment, class: "mt-4 space-y-3" do |f| %><%= f.text_field :name, placeholder: "Installment name", required: true, class: "form-input" %><%= f.number_field :amount, step: 0.01, min: 0.01, placeholder: "Amount", required: true, class: "form-input" %><%= f.date_field :due_on, required: true, class: "form-input" %><%= f.submit "Schedule installment", class: "primary-button w-full" %><% end %><% end %></section>

    <% if current_user.administrator? %><section class="rounded-2xl border border-violet-200 bg-white p-6 shadow-sm"><h2 class="font-bold">Approved adjustment</h2><p class="mt-1 text-xs text-slate-500">Scholarships, discounts, credits, extra charges, or refunds are permanently audited.</p><%= form_with url: invoice_billing_adjustments_path(@invoice), scope: :billing_adjustment, class: "mt-4 space-y-3" do |f| %><%= f.select :kind, BillingAdjustment.kinds.keys.map { |x| [x.humanize, x] }, {}, class: "form-input" %><%= f.number_field :amount, step: 0.01, min: 0.01, placeholder: "Amount", required: true, class: "form-input" %><%= f.text_field :reason, placeholder: "Reason", required: true, class: "form-input" %><%= f.submit "Approve adjustment", class: "primary-button w-full" %><% end %><div class="mt-4 space-y-2"><% @invoice.billing_adjustments.each do |adjustment| %><p class="text-xs"><strong><%= adjustment.kind.humanize %>:</strong> <%= money(adjustment.amount) %> · <%= adjustment.reason %></p><% end %></div></section><% end %>
  </aside>
</div>
