<% content_for :title, "New invoice · SchoolOS" %><%= render "shared/form_header", title: "New invoice", back_path: invoices_path %><%= form_with model: @invoice, class: "mx-auto max-w-2xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: @invoice %><%= f.collection_select :student_id, @students, :id, :full_name, { prompt: "Select student" }, class: "form-input" %><%= f.collection_select :fee_structure_id, @fees, :id, :name, { prompt: "Select fee" }, class: "form-input" %><%= f.number_field :amount, step: 0.01, placeholder: "Amount", class: "form-input" %><%= f.date_field :due_on, class: "form-input" %><%= f.submit "Create invoice", class: "primary-button" %><% end %>
