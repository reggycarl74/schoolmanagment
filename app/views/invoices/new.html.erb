<% content_for :title, "Generate invoices · SchoolOS" %>
<%= render "shared/form_header", title: "Generate invoices", back_path: invoices_path %>

<%= form_with model: @invoice, class: "mx-auto max-w-5xl space-y-6", data: { controller: "checkbox-selection" } do |form| %>
  <%= render "shared/form_errors", object: @invoice %>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
    <div><h2 class="text-xl font-bold text-slate-900">1. Select fee structure</h2><p class="mt-1 text-sm text-slate-500">The selected fee supplies the invoice amount and due date.</p></div>
    <div class="mt-5"><%= form.label :fee_structure_id, "Fee structure", class: "field-label" %><%= form.collection_select :fee_structure_id, @fees, :id, ->(fee) { "#{fee.name} · #{number_to_currency(fee.amount)} · due #{fee.due_on.to_fs(:long)}" }, { prompt: "Select a fee structure" }, { required: true, class: "form-input" } %></div>
  </section>

  <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-4 bg-gradient-to-r from-indigo-50 to-violet-50 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
      <div><h2 class="text-xl font-bold text-slate-900">2. Select students</h2><p class="mt-1 text-sm text-slate-500"><span data-checkbox-selection-target="count">0</span> selected</p></div>
      <label class="flex cursor-pointer items-center gap-3 rounded-xl bg-white px-4 py-3 text-sm font-bold text-indigo-700 shadow-sm"><input type="checkbox" class="h-5 w-5 rounded border-slate-300 text-indigo-600" data-checkbox-selection-target="all" data-action="checkbox-selection#toggleAll"> Select all students</label>
    </div>

    <% if @students.any? %>
      <div class="grid divide-y divide-slate-100 sm:grid-cols-2 sm:divide-y-0 lg:grid-cols-3">
        <% @students.each do |student| %>
          <label class="flex cursor-pointer items-start gap-3 border-slate-100 p-5 transition hover:bg-indigo-50 sm:border-b sm:border-r">
            <%= check_box_tag "invoice[student_ids][]", student.id, Array(params.dig(:invoice, :student_ids)).map(&:to_s).include?(student.id.to_s), id: "invoice_student_#{student.id}", class: "mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-indigo-600", data: { checkbox_selection_target: "item", action: "checkbox-selection#update" } %>
            <span class="min-w-0"><strong class="block truncate text-sm text-slate-900"><%= student.full_name %></strong><small class="block truncate text-xs text-slate-500"><%= student.admission_number %><% if student.classrooms.any? %> · <%= student.classrooms.map(&:name).uniq.join(", ") %><% end %></small></span>
          </label>
        <% end %>
      </div>
    <% else %>
      <p class="p-10 text-center text-slate-500">No active students are available.</p>
    <% end %>
  </section>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end"><%= link_to "Cancel", invoices_path, class: "rounded-xl px-5 py-3 text-center text-sm font-bold text-slate-600 hover:bg-slate-100" %><%= form.submit "Generate selected invoices", class: "primary-button", disabled: @students.empty? || @fees.empty? %></div>
<% end %>
