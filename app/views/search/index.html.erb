<% content_for :title, "Search · SchoolOS" %><div class="rounded-3xl bg-gradient-to-r from-indigo-700 to-violet-700 px-6 py-8 text-white shadow-lg sm:px-8"><p class="text-xs font-bold uppercase tracking-widest text-indigo-200">Global search</p><h1 class="mt-2 text-3xl font-bold">Find anything in SchoolOS</h1><div class="mt-5 max-w-2xl"><%= form_with url: search_path, method: :get, class: "flex gap-2" do |form| %><%= form.search_field :q, value: @query, autofocus: true, placeholder: "Student, teacher, class, lesson, fee...", class: "min-w-0 flex-1 rounded-xl border-0 px-4 py-3 text-slate-900 outline-none ring-4 ring-white/20" %><%= form.submit "Search", class: "rounded-xl bg-white px-5 py-3 font-bold text-indigo-700" %><% end %></div></div>
<% if @query.present? %><div class="mt-8"><p class="text-sm font-semibold text-slate-500">Results for “<strong class="text-slate-900"><%= @query %></strong>”</p><div class="mt-5 grid gap-6 lg:grid-cols-2"><% @results.each do |category, records| %><section class="rounded-3xl border bg-white p-6"><div class="flex items-center justify-between"><h2 class="text-xl font-bold"><%= category %></h2><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700"><%= records.size %></span></div><div class="mt-4 divide-y"><% records.each do |record| %><% path = case record; when Student then student_path(record); when LessonNote then edit_lesson_note_path(record); when Invoice then invoices_path; when FeeStructure then fee_structures_path; else record.respond_to?(:name) && record.is_a?(Classroom) ? classrooms_path : record.is_a?(Subject) ? subjects_path : record.is_a?(Teacher) ? teachers_path : record.is_a?(Guardian) ? guardians_path : announcements_path; end %><%= link_to path, class: "flex items-center justify-between gap-3 py-3 text-sm hover:text-indigo-700" do %><span><strong class="block"><%= record.respond_to?(:full_name) ? record.full_name : record.respond_to?(:topic) ? record.topic : record.respond_to?(:name) ? record.name : record.respond_to?(:title) ? record.title : "Record ##{record.id}" %></strong><small class="text-slate-400"><%= record.class.model_name.human %></small></span><span>→</span><% end %><% end %><% if records.empty? %><p class="py-5 text-sm text-slate-400">No matches</p><% end %></div></section><% end %></div></div><% else %><div class="mt-8 rounded-3xl border-2 border-dashed bg-white p-12 text-center text-slate-500">Enter a name, class, subject, lesson topic, fee, or announcement.</div><% end %>
