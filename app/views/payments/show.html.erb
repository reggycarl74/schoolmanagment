<% content_for :title, "Receipt #{@payment.receipt_number} · SchoolOS" %><% content_for :head do %><style>@media print { header, footer, .no-print { display:none!important } main { max-width:none!important; padding:0!important } }</style><% end %>
<div class="no-print mb-5 flex justify-between"><%= link_to "← Back to invoice", invoice_path(@invoice), class: "font-bold text-indigo-700" %><button onclick="window.print()" class="primary-button">Print receipt</button></div>
<article class="mx-auto max-w-2xl rounded-3xl border bg-white p-8 shadow-lg print:border-0 print:shadow-none"><div class="flex items-start justify-between border-b pb-6"><div><h1 class="text-2xl font-black"><%= current_school.name %></h1><p class="mt-1 text-sm text-slate-500"><%= current_school.address %></p></div><div class="text-right"><p class="text-xs font-bold uppercase tracking-widest text-slate-400">Payment receipt</p><p class="mt-1 font-black text-indigo-700"><%= @payment.receipt_number %></p></div></div><div class="mt-6 grid gap-4 sm:grid-cols-2"><div><p class="text-xs text-slate-400">Received from</p><p class="font-bold"><%= @invoice.student.full_name %></p></div><div><p class="text-xs text-slate-400">Invoice</p><p class="font-bold"><%= @invoice.number %></p></div><div><p class="text-xs text-slate-400">Payment date</p><p class="font-bold"><%= @payment.paid_on.to_fs(:long) %></p></div><div><p class="text-xs text-slate-400">Method / reference</p><p class="font-bold"><%= @payment.payment_method.humanize %> · <%= @payment.reference %></p></div></div><div class="my-8 rounded-2xl bg-emerald-50 p-6 text-center"><p class="text-sm text-emerald-700">Amount received</p><p class="mt-2 text-4xl font-black text-emerald-800"><%= money(@payment.amount) %></p><p class="mt-2 text-sm text-emerald-700">Remaining balance: <%= money(@invoice.balance) %></p></div><p class="text-xs text-slate-500">Recorded by <%= @payment.recorded_by&.full_name || "System" %> on <%= @payment.created_at.to_fs(:long) %>.</p><% if @payment.reversed? %><div class="mt-6 rounded-xl bg-red-50 p-4 text-sm font-bold text-red-700">REVERSED: <%= @payment.reversal_reason %></div><% elsif current_user.administrator? %><%= form_with url: reverse_invoice_payment_path(@invoice, @payment), method: :patch, class: "no-print mt-6 flex gap-3" do |f| %><%= text_field_tag :reversal_reason, nil, required: true, placeholder: "Reason for reversal", class: "form-input" %><%= f.submit "Reverse payment", class: "rounded-xl bg-red-600 px-4 py-3 text-sm font-bold text-white" %><% end %><% end %></article>

<% if current_user.administrator? || current_user.accountant? %><section class="no-print mx-auto mt-5 max-w-2xl rounded-2xl border bg-white p-5 shadow-sm"><h2 class="font-black">Cashbook reconciliation</h2><% if @payment.reconciled? %><p class="mt-3 rounded-xl bg-emerald-50 p-4 text-sm font-bold text-emerald-800">Reconciled by <%= @payment.reconciled_by&.full_name %> · <%= @payment.reconciliation_reference %> · <%= @payment.reconciled_at.to_fs(:long) %></p><% else %><%= form_with url: reconcile_invoice_payment_path(@invoice, @payment), method: :patch, class: "mt-3 flex gap-3" do |form| %><%= text_field_tag :reconciliation_reference, nil, required: true, placeholder: "Bank deposit / cashbook reference", class: "form-input" %><%= form.submit "Reconcile", class: "primary-button" %><% end %><% end %></section><section class="no-print mx-auto mt-5 max-w-2xl rounded-2xl border bg-white p-5 shadow-sm"><div class="flex items-center justify-between"><h2 class="font-black">Parent notifications</h2><span class="text-xs font-bold text-slate-400"><%= @deliveries.size %> sent</span></div><div class="mt-3 divide-y"><% @deliveries.each do |delivery| %><div class="flex items-center justify-between gap-4 py-3 text-sm"><div><strong><%= delivery.recipient.full_name %></strong><p class="text-xs text-slate-500"><%= delivery.channel.upcase %> · <%= delivery.recipient.public_send(delivery.email? ? :email : :phone) %></p></div><span class="rounded-full px-2.5 py-1 text-xs font-bold <%= delivery.delivered? ? 'bg-emerald-50 text-emerald-700' : delivery.failed? ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>"><%= delivery.status.humanize %></span></div><% end %><% if @deliveries.empty? %><p class="py-4 text-sm text-slate-500">No eligible guardian notifications were created.</p><% end %></div></section><% end %>
