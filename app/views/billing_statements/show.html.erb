<% content_for :title, "#{@student.full_name} statement · SchoolOS" %><% content_for :head do %><style>@media print { header, footer, .no-print { display:none!important } }</style><% end %>
<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"><div><p class="text-xs font-bold uppercase tracking-widest text-indigo-600">Student account</p><h1 class="mt-2 text-3xl font-black"><%= @student.full_name %></h1><p class="text-slate-500"><%= @student.admission_number %> · Running ledger and arrears</p></div><button onclick="window.print()" class="no-print primary-button">Print statement</button></div>
<div class="mt-6 rounded-2xl bg-gradient-to-r from-indigo-700 to-violet-700 p-6 text-white"><p class="text-sm text-indigo-200">Current balance</p><p class="mt-2 text-4xl font-black"><%= money(@student.billing_balance) %></p></div>
<% if current_user.administrator? %><%= form_with model: @student, url: student_billing_statement_path(@student), method: :patch, class: "no-print mt-6 flex flex-col gap-3 rounded-2xl border bg-white p-5 sm:flex-row sm:items-end" do |f| %><div class="flex-1"><%= f.label :billing_opening_balance, "Opening balance / arrears brought forward", class: "field-label" %><%= f.number_field :billing_opening_balance, step: 0.01, class: "form-input" %></div><%= f.submit "Update opening balance", class: "primary-button" %><% end %><% end %>
<div class="mt-6 overflow-x-auto rounded-2xl border bg-white"><table class="w-full min-w-[720px] text-left text-sm"><thead class="bg-slate-100"><tr><th class="p-4">Date</th><th class="p-4">Type</th><th class="p-4">Reference</th><th class="p-4">Description</th><th class="p-4 text-right">Debit / credit</th><th class="p-4 text-right">Balance</th></tr></thead><tbody class="divide-y"><% @entries.each do |entry| %><tr><td class="p-4"><%= entry[:date].to_fs(:medium) %></td><td class="p-4"><%= entry[:type] %></td><td class="p-4 font-semibold"><%= entry[:reference] %></td><td class="p-4"><%= entry[:description] %></td><td class="p-4 text-right <%= entry[:amount].negative? ? 'text-emerald-700' : 'text-slate-900' %>"><%= money(entry[:amount]) %></td><td class="p-4 text-right font-bold"><%= money(entry[:balance]) %></td></tr><% end %></tbody></table></div>
