<%= render "shared/form_header", title: "Create classroom post", back_path: classroom_posts_path %><%= form_with model: @post, class: "mx-auto max-w-3xl space-y-5 rounded-3xl border bg-white p-8" do |form| %><%= render "shared/form_errors", object: @post %><%= form.collection_select :course_section_id, @courses, :id, ->(course) { "#{course.classroom.name} · #{course.subject.name} · #{course.term.name}" }, { prompt: "Choose class and subject" }, class: "form-input" %><%= form.select :kind, ClassroomPost.kinds.keys.map { |kind| [kind.humanize, kind] }, {}, class: "form-input" %><%= form.text_field :title, placeholder: "Title", class: "form-input" %><%= form.text_area :body, rows: 7, placeholder: "Instructions or class update", class: "form-input" %><div class="grid gap-4 sm:grid-cols-2"><%= form.datetime_local_field :published_at, class: "form-input" %><%= form.datetime_local_field :due_at, class: "form-input" %></div><%= form.file_field :files, multiple: true, class: "form-input" %><%= form.submit "Publish to classroom", class: "primary-button" %><% end %>
