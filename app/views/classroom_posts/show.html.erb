<% content_for :title, "#{@post.title} · Classroom" %><div class="mx-auto max-w-4xl"><%= link_to "← Classroom", classroom_posts_path, class: "font-bold text-indigo-700" %><article class="mt-5 rounded-3xl border bg-white p-7 shadow-sm"><div class="flex justify-between gap-4"><div><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black text-indigo-700"><%= @post.kind.humanize %></span><h1 class="mt-4 text-3xl font-black"><%= @post.title %></h1><p class="mt-2 text-slate-500"><%= @post.course_section.classroom.name %> · <%= @post.course_section.subject.name %></p></div><% if @post.due_at %><strong class="text-amber-700">Due <%= @post.due_at.to_fs(:long) %></strong><% end %></div><p class="mt-6 whitespace-pre-line text-slate-700"><%= @post.body %></p><div class="mt-5 flex flex-wrap gap-2"><% @post.files.each do |file| %><%= link_to file.filename.to_s, rails_blob_path(file, disposition: "attachment"), class: "rounded-full bg-slate-100 px-3 py-2 text-sm font-bold" %><% end %></div></article><% if current_user.student? && @post.assignment? %><%= form_with model: @submission, url: @submission.persisted? ? classroom_post_student_submission_path(@post, @submission) : classroom_post_student_submissions_path(@post), class: "mt-6 space-y-4 rounded-3xl border bg-white p-7" do |form| %><h2 class="text-xl font-black">Your work</h2><%= form.text_area :body, rows: 5, placeholder: "Write an answer or note", class: "form-input" %><%= form.file_field :files, multiple: true, class: "form-input" %><%= form.submit @submission.persisted? ? "Resubmit work" : "Turn in work", class: "primary-button" %><% end %><% elsif current_user.teacher? || current_user.administrator? %><section class="mt-6 rounded-3xl border bg-white p-7"><h2 class="text-xl font-black">Student submissions</h2><div class="mt-4 space-y-4"><% @post.student_submissions.includes(:student).each do |submission| %><div class="rounded-2xl bg-slate-50 p-4"><strong><%= submission.student.full_name %></strong><p class="mt-2 text-sm"><%= submission.body %></p><%= form_with model: submission, url: classroom_post_student_submission_path(@post, submission), class: "mt-3 grid gap-3 sm:grid-cols-3" do |form| %><%= form.number_field :score, step: 0.01, placeholder: "Score", class: "form-input" %><%= form.text_field :feedback, placeholder: "Feedback", class: "form-input" %><%= form.select :status, [["Returned", "returned"], ["Graded", "graded"]], {}, class: "form-input" %><%= form.submit "Save feedback", class: "primary-button sm:col-span-3" %><% end %></div><% end %></div></section><% end %></div>
