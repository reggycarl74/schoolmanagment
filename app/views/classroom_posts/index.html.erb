<% content_for :title, "Classroom · SchoolOS" %><%= render "shared/section_header", title: "Classroom", subtitle: "Assignments, learning materials, class updates, and submissions", button_text: "Create post", button_path: (new_classroom_post_path if current_user.teacher? || current_user.administrator?) %><div class="mt-8 grid gap-5"><% @posts.each do |post| %><%= link_to classroom_post_path(post), class: "block rounded-3xl border bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %><div class="flex items-start justify-between gap-4"><div><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black text-indigo-700"><%= post.kind.humanize %></span><h2 class="mt-3 text-xl font-black"><%= post.title %></h2><p class="mt-1 text-sm text-slate-500"><%= post.course_section.classroom.name %> · <%= post.course_section.subject.name %> · <%= post.author.full_name %></p></div><% if post.due_at %><span class="text-sm font-bold text-amber-700">Due <%= post.due_at.to_fs(:short) %></span><% end %></div><p class="mt-4 line-clamp-3 text-slate-700"><%= post.body %></p><div class="mt-4 flex gap-4 text-xs font-semibold text-slate-400"><span><%= post.files.size %> files</span><span><%= post.student_submissions.size %> submissions</span></div><% end %><% end %><% if @posts.empty? %><div class="rounded-3xl border-2 border-dashed bg-white p-12 text-center text-slate-500">No classroom posts yet.</div><% end %></div>
