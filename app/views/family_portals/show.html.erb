<% content_for :title, "Family portal · SchoolOS" %><div class="rounded-3xl bg-gradient-to-r from-violet-700 to-indigo-700 p-7 text-white"><p class="text-xs font-bold uppercase tracking-widest text-indigo-200">Family portal</p><h1 class="mt-2 text-3xl font-black"><%= current_user.student? ? "My school dashboard" : "My children" %></h1><p class="mt-2 text-indigo-100">Academics, attendance, assignments, announcements, and billing in one place.</p></div><div class="mt-6 grid gap-5 md:grid-cols-2"><% @students.each do |student| %><article class="rounded-3xl border bg-white p-6 shadow-sm"><h2 class="text-xl font-black"><%= student.full_name %></h2><p class="mt-1 text-sm text-slate-500"><%= student.enrollments.select(&:enrolled?).map { |entry| entry.classroom.name }.to_sentence.presence || "No active class" %></p><div class="mt-5 grid grid-cols-2 gap-3"><%= link_to "Report card", report_card_path(student), class: "rounded-xl bg-indigo-50 p-3 text-center text-sm font-bold text-indigo-700" %><%= link_to "Assessments", assessments_student_path(student), class: "rounded-xl bg-violet-50 p-3 text-center text-sm font-bold text-violet-700" %><%= link_to "Billing", student_billing_statement_path(student), class: "rounded-xl bg-amber-50 p-3 text-center text-sm font-bold text-amber-700" %><%= link_to "Classroom", classroom_posts_path, class: "rounded-xl bg-emerald-50 p-3 text-center text-sm font-bold text-emerald-700" %></div></article><% end %></div><div class="mt-6 grid gap-6 xl:grid-cols-3"><section class="rounded-3xl border bg-white p-6"><h2 class="font-black">Recent attendance</h2><div class="mt-3 divide-y"><% @recent_attendance.each do |record| %><div class="py-3 text-sm"><strong><%= record.enrollment.student.full_name %></strong><p class="text-xs text-slate-500"><%= record.attendance_date %> · <%= record.status.humanize %><%= " · #{record.absence_reason}" if record.absence_reason.present? %></p></div><% end %></div></section><section class="rounded-3xl border bg-white p-6"><h2 class="font-black">Assignments</h2><div class="mt-3 divide-y"><% @submissions.each do |submission| %><div class="py-3 text-sm"><strong><%= submission.classroom_post.title %></strong><p class="text-xs text-slate-500"><%= submission.student.full_name %> · <%= submission.status.humanize %><%= " · Score #{submission.score}" if submission.score %></p></div><% end %><% if @submissions.empty? %><p class="py-3 text-sm text-slate-500">No submissions yet.</p><% end %></div></section><section class="rounded-3xl border bg-white p-6"><h2 class="font-black">Outstanding fees</h2><div class="mt-3 divide-y"><% @open_invoices.each do |invoice| %><%= link_to invoice_path(invoice), class: "block py-3 text-sm" do %><strong><%= invoice.student.full_name %></strong><p class="text-xs text-slate-500"><%= invoice.number %> · Due <%= invoice.due_on %> · <%= money(invoice.balance) %></p><% end %><% end %><% if @open_invoices.empty? %><p class="py-3 text-sm font-bold text-emerald-700">No outstanding invoices.</p><% end %></div></section></div><section class="mt-6 rounded-3xl border bg-white p-6"><h2 class="font-black">School announcements</h2><div class="mt-3 grid gap-3 md:grid-cols-2"><% @announcements.each do |announcement| %><article class="rounded-xl bg-slate-50 p-4"><strong><%= announcement.title %></strong><p class="mt-2 text-sm text-slate-600"><%= truncate(announcement.body, length: 180) %></p></article><% end %></div></section>
