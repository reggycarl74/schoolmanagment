<% content_for :title, "Change user password · SchoolOS" %>
<%= render "shared/form_header", title: "Change user password", back_path: admin_users_path %>

<div class="mx-auto mt-8 max-w-2xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg">
  <div class="bg-gradient-to-r from-indigo-700 via-violet-700 to-fuchsia-600 px-6 py-7 text-white sm:px-8">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-200"><%= @user.role.humanize %> account</p>
    <h1 class="mt-2 text-2xl font-bold"><%= @user.full_name %></h1>
    <p class="mt-1 text-sm text-indigo-100"><%= @user.email %></p>
  </div>

  <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "space-y-6 p-6 sm:p-8", data: { controller: "password-visibility" } do |form| %>
    <%= render "shared/form_errors", object: @user %>
    <p class="rounded-2xl bg-amber-50 p-4 text-sm leading-6 text-amber-800">The user will need to use this new password the next time they sign in. Their current password is not required for an administrator reset.</p>
    <div class="flex justify-end"><button type="button" class="text-xs font-bold text-indigo-700" data-action="password-visibility#toggle" data-password-visibility-target="label">Show passwords</button></div>
    <div><%= form.label :password, "New password", class: "field-label" %><%= form.password_field :password, required: true, minlength: 8, autocomplete: "new-password", class: "form-input", data: { password_visibility_target: "field" } %><p class="mt-2 text-xs text-slate-500">Use at least 8 characters.</p></div>
    <div><%= form.label :password_confirmation, "Confirm new password", class: "field-label" %><%= form.password_field :password_confirmation, required: true, minlength: 8, autocomplete: "new-password", class: "form-input", data: { password_visibility_target: "field" } %></div>
    <div class="flex flex-col-reverse gap-3 border-t border-slate-100 pt-5 sm:flex-row sm:justify-end"><%= link_to "Cancel", admin_users_path, class: "rounded-xl px-5 py-3 text-center text-sm font-bold text-slate-600 hover:bg-slate-100" %><%= form.submit "Change password", class: "primary-button" %></div>
  <% end %>
</div>
