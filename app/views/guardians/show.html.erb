<% content_for :title, "#{@guardian.full_name} · SchoolOS" %>
<div class="rounded-3xl bg-gradient-to-r from-cyan-600 via-indigo-700 to-violet-700 p-6 text-white shadow-lg sm:p-8">
  <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"><div><%= link_to "← Guardians", guardians_path, class: "text-sm font-bold text-cyan-100" %><p class="mt-5 text-xs font-black uppercase tracking-widest text-cyan-200">Family contact</p><h1 class="mt-1 text-3xl font-black"><%= @guardian.full_name %></h1><p class="mt-2 text-indigo-100"><%= @guardian.phone %><%= " · #{@guardian.email}" if @guardian.email.present? %></p></div><div class="flex flex-wrap gap-2"><%= link_to "Edit profile", edit_guardian_path(@guardian), class: "rounded-xl bg-white/15 px-4 py-3 text-sm font-bold text-white backdrop-blur hover:bg-white/25" %><% if current_user.administrator? %><% if @guardian.user %><%= button_to @guardian.user.active? ? "Disable portal" : "Enable portal", toggle_portal_access_guardian_path(@guardian), method: :patch, class: "rounded-xl bg-white px-4 py-3 text-sm font-bold text-indigo-700" %><% else %><%= button_to "Invite to portal", invite_guardian_path(@guardian), class: "rounded-xl bg-white px-4 py-3 text-sm font-bold text-indigo-700" %><% end %><% end %></div></div>
</div>

<div class="mt-6 grid gap-6 xl:grid-cols-[1.6fr_1fr]">
  <main class="space-y-6">
    <section class="rounded-3xl border bg-white p-6 shadow-sm"><div class="flex items-center justify-between"><h2 class="text-xl font-black">Linked students</h2><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-black text-indigo-700"><%= @relationships.size %></span></div><div class="mt-5 space-y-4"><% @relationships.each do |relationship| %><article class="rounded-2xl border border-slate-200 p-5"><div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"><div><%= link_to relationship.student.full_name, student_path(relationship.student), class: "text-lg font-black text-indigo-700" %><p class="text-sm text-slate-500"><%= relationship.relationship %><%= " · Primary contact" if relationship.primary_contact? %></p><p class="mt-1 text-xs text-slate-400"><%= relationship.student.enrollments.select(&:enrolled?).map { |enrollment| enrollment.classroom.name }.to_sentence.presence || "No active class" %> · Balance <%= money(relationship.student.billing_balance) %></p></div><div class="flex flex-wrap gap-1.5"><% { emergency_contact: "Emergency", pickup_authorized: "Pickup", academic_access: "Academics", attendance_access: "Attendance", billing_access: "Billing" }.each do |permission, label| %><span class="rounded-full px-2.5 py-1 text-xs font-bold <%= relationship.public_send(permission) ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-400' %>"><%= label %></span><% end %></div></div><% if relationship.custody_restrictions.present? %><p class="mt-4 rounded-xl bg-red-50 p-3 text-sm font-semibold text-red-800"><strong>Restriction:</strong> <%= relationship.custody_restrictions %></p><% end %><% if relationship.pickup_notes.present? %><p class="mt-3 text-sm text-slate-600"><strong>Pickup:</strong> <%= relationship.pickup_notes %></p><% end %></article><% end %><% if @relationships.empty? %><p class="rounded-2xl bg-amber-50 p-5 text-sm text-amber-800">No students are linked to this guardian.</p><% end %></div></section>
    <section class="rounded-3xl border bg-white p-6 shadow-sm"><h2 class="text-xl font-black">Recent communication</h2><div class="mt-4 divide-y"><% @recent_deliveries.each do |delivery| %><div class="py-4"><div class="flex justify-between gap-4"><strong class="text-sm"><%= delivery.subject %></strong><span class="text-xs font-bold <%= delivery.delivered? ? 'text-emerald-700' : delivery.failed? ? 'text-red-600' : 'text-amber-600' %>"><%= delivery.status.humanize %></span></div><p class="mt-1 text-xs text-slate-500"><%= delivery.channel.humanize %> · <%= delivery.created_at.to_fs(:long) %></p></div><% end %><% if @recent_deliveries.empty? %><p class="py-5 text-sm text-slate-500">No communication history yet.</p><% end %></div></section>
  </main>
  <aside class="space-y-6">
    <section class="rounded-3xl border bg-white p-6 shadow-sm"><h2 class="font-black">Contact profile</h2><dl class="mt-4 space-y-4 text-sm"><div><dt class="text-xs font-bold uppercase text-slate-400">Preferred contact</dt><dd class="mt-1 font-semibold"><%= @guardian.preferred_contact_method.humanize %> · <%= @guardian.preferred_language %></dd></div><div><dt class="text-xs font-bold uppercase text-slate-400">Alternative phone</dt><dd class="mt-1"><%= @guardian.alternate_phone.presence || "Not provided" %></dd></div><div><dt class="text-xs font-bold uppercase text-slate-400">Occupation</dt><dd class="mt-1"><%= @guardian.occupation.presence || "Not provided" %></dd></div><div><dt class="text-xs font-bold uppercase text-slate-400">Address</dt><dd class="mt-1 whitespace-pre-line"><%= @guardian.address.presence || "Not provided" %></dd></div></dl></section>
    <section class="rounded-3xl border bg-white p-6 shadow-sm"><h2 class="font-black">Portal access</h2><p class="mt-3 text-sm text-slate-600">Status: <strong><%= @guardian.portal_status.humanize %></strong></p><% if @guardian.user %><p class="mt-1 text-xs text-slate-500"><%= @guardian.user.email %></p><% end %><% if current_user.administrator? && @guardian.email.present? %><%= button_to @guardian.user ? "Resend password setup" : "Create portal account", invite_guardian_path(@guardian), class: "mt-4 w-full rounded-xl bg-indigo-50 px-4 py-3 text-sm font-bold text-indigo-700" %><% end %></section>
    <% if @guardian.private_notes.present? %><section class="rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="font-black text-amber-900">Private staff notes</h2><p class="mt-3 whitespace-pre-line text-sm text-amber-900"><%= @guardian.private_notes %></p></section><% end %>
  </aside>
</div>
