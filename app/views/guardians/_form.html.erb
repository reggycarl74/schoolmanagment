<%= form_with model: guardian, class: "mx-auto max-w-2xl space-y-5 rounded-2xl border bg-white p-8" do |f| %><%= render "shared/form_errors", object: guardian %><div class="grid grid-cols-2 gap-4"><%= f.text_field :first_name, placeholder: "First name", class: "form-input" %><%= f.text_field :last_name, placeholder: "Last name", class: "form-input" %></div><%= f.email_field :email, placeholder: "Email", class: "form-input" %><%= f.telephone_field :phone, placeholder: "Phone", class: "form-input" %><%= f.text_area :address, placeholder: "Address", class: "form-input" %><div><p class="field-label">Children</p><div class="mt-2 grid grid-cols-2 gap-2"><% @students.each do |student| %><label class="flex gap-2"><%= check_box_tag "student_ids[]", student.id, guardian.student_ids.include?(student.id) %><%= student.full_name %></label><% end %></div></div><%= f.submit class: "primary-button" %><% end %>
