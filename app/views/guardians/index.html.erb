<% content_for :title, "Guardians · SchoolOS" %><%= render "shared/section_header", title: "Guardians", subtitle: "Families and authorized contacts", button_text: "Add guardian", button_path: new_guardian_path %><div class="mt-8 divide-y rounded-2xl border bg-white"><% @guardians.each do |guardian| %><div class="flex justify-between p-5"><div><strong><%= guardian.full_name %></strong><p class="text-sm text-slate-500"><%= guardian.phone %> · <%= guardian.students.map(&:full_name).to_sentence %></p></div><%= link_to "Edit", edit_guardian_path(guardian), class: "text-sm font-semibold text-indigo-700" %></div><% end %></div>
