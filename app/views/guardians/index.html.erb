<% content_for :title, "Guardians · SchoolOS" %>
<%= render "shared/section_header", title: "Guardians", subtitle: "Family contacts, permissions, emergency access, and portal accounts", button_text: "Add guardian", button_path: new_guardian_path %>

<%= form_with url: guardians_path, method: :get, class: "mt-6 grid gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:grid-cols-[1fr_auto_auto_auto]" do |form| %>
  <%= form.search_field :query, value: params[:query], placeholder: "Search guardian, phone, email, or student", class: "form-input" %>
  <%= form.select :active, [["All records", ""], ["Active", "true"], ["Inactive", "false"]], { selected: params[:active] }, class: "form-input" %>
  <%= form.select :portal, [["All portal statuses", ""], ["Portal active", "active"], ["Portal disabled", "disabled"], ["Not invited", "not_invited"]], { selected: params[:portal] }, class: "form-input" %>
  <%= form.submit "Search", class: "primary-button" %>
<% end %>

<div class="mt-6 grid gap-4 lg:grid-cols-2">
  <% @guardians.each do |guardian| %>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
      <div class="flex items-start justify-between gap-4">
        <div class="flex min-w-0 items-center gap-3">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-500 to-indigo-600 font-black text-white"><%= guardian.first_name.first %><%= guardian.last_name.first %></span>
          <div class="min-w-0"><%= link_to guardian.full_name, guardian_path(guardian), class: "truncate text-lg font-black text-slate-900 hover:text-indigo-700" %><p class="truncate text-sm text-slate-500"><%= guardian.phone %><%= " · #{guardian.email}" if guardian.email.present? %></p></div>
        </div>
        <span class="rounded-full px-2.5 py-1 text-xs font-bold <%= guardian.active? ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>"><%= guardian.active? ? "Active" : "Inactive" %></span>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <% guardian.student_guardians.each do |relationship| %><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700"><%= relationship.student.full_name %> · <%= relationship.relationship %></span><% end %>
        <% if guardian.student_guardians.empty? %><span class="text-xs text-amber-700">No students linked</span><% end %>
      </div>
      <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4 text-xs">
        <span class="font-bold <%= guardian.portal_status == 'active' ? 'text-emerald-700' : guardian.portal_status == 'disabled' ? 'text-red-600' : 'text-slate-400' %>">Portal: <%= guardian.portal_status.humanize %></span>
        <div class="flex gap-3"><%= link_to "View", guardian_path(guardian), class: "font-bold text-indigo-700" %><%= link_to "Edit", edit_guardian_path(guardian), class: "font-bold text-violet-700" %></div>
      </div>
    </article>
  <% end %>
</div>

<% if @guardians.empty? %><div class="mt-6 rounded-3xl border-2 border-dashed bg-white p-12 text-center text-slate-500">No guardians match those filters.</div><% end %>
