<% content_for :title, "School settings · SchoolOS" %>
<h1 class="text-3xl font-bold">School profile and report cards</h1>
<p class="mt-2 text-slate-500">Manage the logo and contact information printed on report cards, plus each term's reopening date.</p>

<%= form_with model: current_school, url: school_setting_path, method: :patch, class: "mt-8 max-w-3xl space-y-6 rounded-2xl border bg-white p-6 shadow-sm" do |form| %>
  <section>
    <h2 class="text-xl font-bold">School branding</h2>
    <% if current_school.logo.attached? %><div class="mt-4 flex items-center gap-4"><%= image_tag current_school.logo, class: "h-24 w-24 rounded-xl border object-contain p-2", alt: "#{current_school.name} logo" %><label class="text-sm text-red-700"><%= check_box_tag :remove_logo, "1" %> Remove current logo</label></div><% end %>
    <div class="mt-4"><%= form.label :logo, "School image/logo", class: "field-label" %><%= form.file_field :logo, accept: "image/png,image/jpeg,image/webp", class: "form-input" %><p class="mt-1 text-xs text-slate-500">PNG, JPEG, or WebP; maximum 5 MB.</p></div>
    <div class="mt-4 grid gap-4 md:grid-cols-2"><div><%= form.label :name, class: "field-label" %><%= form.text_field :name, required: true, class: "form-input" %></div><div><%= form.label :email, class: "field-label" %><%= form.email_field :email, class: "form-input" %></div><div><%= form.label :phone, class: "field-label" %><%= form.telephone_field :phone, class: "form-input" %></div><div><%= form.label :address, class: "field-label" %><%= form.text_field :address, class: "form-input" %></div></div>
  </section>
  <section class="border-t pt-6"><h2 class="text-xl font-bold">Reopening date</h2><p class="mt-1 text-sm text-slate-500">Choose the term whose report card should show the date.</p><div class="mt-4 grid gap-4 md:grid-cols-2"><div><%= label_tag :term_id, "Report term", class: "field-label" %><%= select_tag :term_id, options_from_collection_for_select(@terms, :id, ->(term) { "#{term.academic_year.name} · #{term.name}" }), include_blank: "Select term", class: "form-input" %></div><div><%= label_tag :reopening_date, "School reopens on", class: "field-label" %><%= date_field_tag :reopening_date, nil, class: "form-input" %></div></div></section>
  <%= form.submit "Save school settings", class: "primary-button" %>
<% end %>
