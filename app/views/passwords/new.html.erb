<% content_for :title, "Forgot password · SchoolOS" %><%= form_with url: passwords_path, class: "mx-auto mt-16 max-w-md space-y-5 rounded-2xl border bg-white p-8" do |f| %><h1 class="text-2xl font-bold">Forgot password</h1><%= f.email_field :email, placeholder: "Email address", required: true, class: "form-input" %><%= f.submit "Send reset instructions", class: "primary-button w-full" %><% end %>
