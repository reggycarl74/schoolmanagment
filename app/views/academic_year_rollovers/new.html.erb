<% content_for :title, "Academic year rollover · SchoolOS" %><h1 class="text-3xl font-bold">Academic year rollover</h1><p class="mt-2 text-slate-500">Create the next year, its three terms, and carry selected classes and students forward.</p>
<% if @source_year %><%= form_with url: academic_year_rollover_path, scope: :academic_year, class: "mt-6 max-w-3xl space-y-6 rounded-2xl border bg-white p-6" do |form| %><%= hidden_field_tag :source_year_id, @source_year.id %><div class="grid gap-4 md:grid-cols-3"><div><%= form.label :name, class: "field-label" %><%= form.text_field :name, required: true, placeholder: "2027/2028", class: "form-input" %></div><div><%= form.label :starts_on, class: "field-label" %><%= form.date_field :starts_on, required: true, class: "form-input" %></div><div><%= form.label :ends_on, class: "field-label" %><%= form.date_field :ends_on, required: true, class: "form-input" %></div></div><fieldset><legend class="font-bold">Classes from <%= @source_year.name %></legend><div class="mt-3 grid gap-2 sm:grid-cols-2"><% @classrooms.each do |classroom| %><label class="rounded-lg border p-3"><%= check_box_tag "classroom_ids[]", classroom.id, true %> <%= classroom.name %></label><% end %></div></fieldset><%= form.submit "Create year and roll over", class: "primary-button", data: { turbo_confirm: "Create the new year and complete current enrollments?" } %><% end %><% else %><p class="mt-6 rounded-xl bg-amber-50 p-4">Create an academic year before using rollover.</p><% end %>
