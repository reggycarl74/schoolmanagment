<% content_for :title, "Teacher assignments · SchoolOS" %>
<%= render "shared/section_header", title: "Teacher assignments", subtitle: "Connect teachers to classes and subjects", button_text: "Assign teacher", button_path: new_teaching_assignment_path %>
<div class="mt-8 overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm"><table class="w-full min-w-[750px] text-left text-sm"><thead class="bg-slate-50 text-slate-600"><tr><th class="p-4">Teacher</th><th class="p-4">Class</th><th class="p-4">Subject</th><th class="p-4">Duration</th><th class="p-4">Role</th><th class="p-4"></th></tr></thead><tbody class="divide-y divide-slate-100"><% @assignments.each do |assignment| %><tr><td class="p-4 font-semibold"><%= assignment.teacher.full_name %></td><td class="p-4"><%= assignment.classroom.name %></td><td class="p-4"><%= assignment.subject.name %></td><td class="p-4"><span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700">All terms · until changed</span></td><td class="p-4"><%= assignment.lead? ? "Lead teacher" : "Supporting teacher" %></td><td class="p-4 text-right"><div class="flex justify-end gap-3"><%= link_to "Edit", edit_teaching_assignment_path(assignment), class: "text-sm font-semibold text-indigo-700" %><%= button_to "Remove", teaching_assignment_path(assignment), method: :delete, class: "text-sm font-semibold text-red-600 hover:text-red-800", form: { data: { turbo_confirm: "Remove this teacher assignment?" } } %></div></td></tr><% end %></tbody></table><% if @assignments.empty? %><p class="p-10 text-center text-slate-500">No teacher assignments yet.</p><% end %></div>
