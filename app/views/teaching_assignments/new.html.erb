<% content_for :title, "Assign teacher · SchoolOS" %>
<%= render "shared/form_header", title: "Assign teacher", back_path: teaching_assignments_path %>
<%= form_with model: @assignment, class: "mx-auto max-w-3xl space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm" do |form| %><%= render "shared/form_errors", object: @assignment %><div class="rounded-xl bg-indigo-50 p-4 text-sm font-semibold text-indigo-800">This assignment applies to every term and remains active until an administrator edits or removes it.</div><div class="grid gap-5 sm:grid-cols-2"><div><%= form.label :teacher_id, class: "field-label" %><%= form.collection_select :teacher_id, @teachers, :id, :full_name, { prompt: "Select teacher" }, { required: true, class: "form-input" } %></div><div><%= form.label :classroom_id, "Class", class: "field-label" %><%= form.collection_select :classroom_id, @classrooms, :id, :name, { prompt: "Select class" }, { required: true, class: "form-input" } %></div><div><%= form.label :subject_id, class: "field-label" %><%= form.collection_select :subject_id, @subjects, :id, :name, { prompt: "Select subject" }, { required: true, class: "form-input" } %></div></div><label class="flex items-center gap-3 text-sm font-medium text-slate-700"><%= form.check_box :lead, checked: true, class: "size-4 rounded border-slate-300 text-indigo-700" %>Lead teacher for this subject</label><%= form.submit "Save assignment", class: "primary-button" %><% end %>
