<% content_for :title, "Add class · SchoolOS" %>
<%= render "shared/form_header", title: "Add class", back_path: classrooms_path %>
<%= form_with model: @classroom, class: "mx-auto max-w-3xl space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm" do |form| %>
  <%= render "shared/form_errors", object: @classroom %><div class="grid gap-5 sm:grid-cols-2">
    <%= render "shared/text_field", form:, field: :name, label: "Class name" %>
    <div><%= form.label :academic_year_id, class: "field-label" %><%= form.collection_select :academic_year_id, @academic_years, :id, :name, { prompt: "Select academic year" }, { required: true, class: "form-input" } %></div>
    <div><%= form.label :grade_level_id, class: "field-label" %><%= form.collection_select :grade_level_id, @grade_levels, :id, :name, { prompt: "Select grade" }, { required: true, class: "form-input" } %></div>
    <div><%= form.label :homeroom_teacher_id, class: "field-label" %><%= form.collection_select :homeroom_teacher_id, @teachers, :id, :full_name, { include_blank: "No homeroom teacher" }, { class: "form-input" } %></div>
    <div><%= form.label :capacity, class: "field-label" %><%= form.number_field :capacity, min: 1, class: "form-input" %></div>
  </div><%= form.submit "Save class", class: "primary-button" %>
<% end %>
