<% content_for :title, "Classes · SchoolOS" %>
<%= render "shared/section_header", title: "Classes", subtitle: "Classes for each academic year", button_text: "Add class", button_path: (new_classroom_path if current_user.administrator?) %>
<div class="mt-8 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"><% if @records.any? %><ul class="divide-y divide-slate-100"><% @records.each do |record| %><li class="flex items-center justify-between px-6 py-4"><div><p class="font-semibold"><%= record.name %></p><p class="text-sm text-slate-500"><%= record.grade_level.name %> · <%= record.academic_year.name %></p></div><span class="text-sm text-slate-500"><%= record.homeroom_teacher&.full_name || "No homeroom teacher" %></span></li><% end %></ul><% else %><p class="p-10 text-center text-slate-500">No classes yet.</p><% end %></div>
