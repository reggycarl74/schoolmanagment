<%= form_with model: lesson_note, class: "mx-auto max-w-4xl space-y-7 rounded-3xl border border-slate-200 bg-white p-6 shadow-lg sm:p-8" do |form| %>
  <%= form.hidden_field :record_id, value: lesson_note.id if lesson_note.persisted? %>
  <%= render "shared/form_errors", object: lesson_note, form_error: @form_error %>
  <section><div class="flex items-center gap-3"><span class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100">📅</span><div><h2 class="font-bold text-slate-900">Class and schedule</h2><p class="text-xs text-slate-500">Choose an assigned subject and teaching date; the correct term is selected automatically.</p></div></div><div class="mt-5 grid gap-5 sm:grid-cols-2"><div class="sm:col-span-2"><%= form.label :teaching_assignment_id, "Assigned class and subject", class: "field-label" %><%= form.collection_select :teaching_assignment_id, @assignments, :id, ->(assignment) { "#{assignment.classroom.name} · #{assignment.subject.name} · #{assignment.teacher.full_name}" }, { prompt: "Select an assigned class", selected: @assignments.find { |assignment| assignment.classroom_id == lesson_note.course_section&.classroom_id && assignment.subject_id == lesson_note.course_section&.subject_id && assignment.teacher_id == lesson_note.teacher_id }&.id }, { required: true, class: "form-input" } %></div><div><%= form.label :lesson_date, "Teaching date", class: "field-label" %><%= form.date_field :lesson_date, required: true, class: "form-input" %></div><div class="grid grid-cols-2 gap-3"><div><%= form.label :starts_at, "Start time", class: "field-label" %><%= form.time_field :starts_at, class: "form-input" %></div><div><%= form.label :duration_minutes, "Minutes", class: "field-label" %><%= form.number_field :duration_minutes, min: 1, max: 480, class: "form-input" %></div></div><div><%= form.label :status, class: "field-label" %><%= form.select :status, LessonNote.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "form-input" %></div><div><%= form.label :topic, class: "field-label" %><%= form.text_field :topic, required: true, placeholder: "Fractions and equivalent values", class: "form-input" %></div></div></section>
  <section class="border-t border-slate-200 pt-7"><div class="flex items-center gap-3"><span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100">🎯</span><div><h2 class="font-bold text-slate-900">Lesson plan</h2><p class="text-xs text-slate-500">Describe what students will learn and how you will teach it.</p></div></div><div class="mt-5 space-y-5"><div><%= form.label :objectives, "Learning objectives", class: "field-label" %><%= form.text_area :objectives, rows: 3, placeholder: "By the end of the lesson, students will be able to...", class: "form-input" %></div><div><%= form.label :materials, "Materials and resources", class: "field-label" %><%= form.text_area :materials, rows: 2, placeholder: "Textbook, worksheets, projector...", class: "form-input" %></div><div><%= form.label :content, "Teaching activities and lesson content", class: "field-label" %><%= form.text_area :content, rows: 7, required: true, placeholder: "Introduction, teacher activity, student activity, assessment and conclusion...", class: "form-input" %></div><div><%= form.label :homework, "Homework or follow-up", class: "field-label" %><%= form.text_area :homework, rows: 3, class: "form-input" %></div></div></section>
  <section class="border-t border-slate-200 pt-7"><div class="flex items-center gap-3"><span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100">📎</span><div><h2 class="font-bold text-slate-900">Upload lesson notes</h2><p class="text-xs text-slate-500">Attach a text-based PDF, DOCX, PPTX, or TXT file and preview the extracted plan before saving.</p></div></div><div class="mt-5 rounded-2xl border-2 border-dashed border-indigo-200 bg-indigo-50/50 p-5"><%= form.file_field :files, multiple: true, accept: ".txt,.pdf,.docx,.pptx,.png,.jpg,.jpeg,.webp", class: "block w-full text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-indigo-700 file:px-4 file:py-2.5 file:font-bold file:text-white hover:file:bg-indigo-800" %><label class="mt-4 flex items-start gap-3 rounded-xl bg-white p-3 text-sm"><%= form.check_box :prefill_from_files, checked: true, class: "mt-1" %><span><strong>Fill blank lesson-plan fields from this document</strong><small class="block text-slate-500">Your typed fields are never overwritten. Scanned images remain attachments because they do not contain readable text.</small></span></label><%= form.submit "Extract document and preview", formaction: extract_lesson_notes_path, formmethod: :post, class: "mt-4 rounded-xl bg-amber-500 px-5 py-3 text-sm font-bold text-white hover:bg-amber-600" %></div><% Array(@pending_blobs).each do |blob| %><%= form.hidden_field :existing_blob_ids, multiple: true, value: blob.signed_id %><% end %><% if @pending_blobs.present? %><div class="mt-4 rounded-xl bg-emerald-50 p-4 text-sm font-semibold text-emerald-800">✓ Document extracted. Review the populated fields above, make any changes, then save the lesson plan.</div><% end %><% if lesson_note.files.attached? %><div class="mt-4 flex flex-wrap gap-2"><% lesson_note.files.each do |file| %><%= link_to file.filename.to_s, rails_blob_path(file, disposition: "attachment"), class: "rounded-full bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-700" %><% end %></div><% end %></section>
  <div class="flex flex-col-reverse gap-3 border-t border-slate-100 pt-6 sm:flex-row sm:justify-end"><%= link_to "Cancel", lesson_notes_path, class: "rounded-xl px-5 py-3 text-center text-sm font-bold text-slate-600 hover:bg-slate-100" %><%= form.submit lesson_note.persisted? ? "Save lesson plan" : "Create lesson plan", class: "primary-button" %></div>
<% end %>
