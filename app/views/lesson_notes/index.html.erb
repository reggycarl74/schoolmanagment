<% content_for :title, "Lesson plans · SchoolOS" %><%= render "shared/section_header", title: "Lesson plans", subtitle: "Plan, schedule and upload teaching resources", button_text: "Create lesson plan", button_path: new_lesson_note_path %>
<% if current_user.administrator? %><%= form_with url: lesson_notes_path, method: :get, class: "mt-6 grid gap-4 rounded-2xl border bg-white p-5 sm:grid-cols-3 sm:items-end" do |form| %><div><%= form.label :teacher_id, "Teacher", class: "field-label" %><%= form.collection_select :teacher_id, @teachers, :id, :full_name, { include_blank: "All teachers", selected: params[:teacher_id] }, class: "form-input" %></div><div><%= form.label :classroom_id, "Class", class: "field-label" %><%= form.collection_select :classroom_id, @classrooms, :id, :name, { include_blank: "All classes", selected: params[:classroom_id] }, class: "form-input" %></div><%= form.submit "Filter lesson plans", class: "primary-button" %><% end %><% end %>
<div class="mt-8 grid gap-5 lg:grid-cols-2"><% @lesson_notes.each do |note| %><article class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"><div class="h-1.5 <%= note.draft? ? 'bg-amber-400' : note.ready? ? 'bg-indigo-500' : 'bg-emerald-500' %>"></div><div class="p-6"><div class="flex flex-wrap items-start justify-between gap-4"><div><div class="flex flex-wrap gap-2"><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700"><%= note.course_section.subject.name %></span><span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600"><%= note.course_section.classroom.name %></span></div><h2 class="mt-4 text-xl font-bold text-slate-900"><%= note.topic %></h2></div><span class="rounded-full px-3 py-1 text-xs font-bold <%= note.draft? ? 'bg-amber-100 text-amber-700' : note.ready? ? 'bg-indigo-100 text-indigo-700' : 'bg-emerald-100 text-emerald-700' %>"><%= note.status.humanize %></span></div><div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-slate-500"><span>📅 <%= note.lesson_date.to_fs(:long) %></span><% if note.starts_at %><span>🕐 <%= note.starts_at.strftime("%H:%M") %></span><% end %><% if note.duration_minutes %><span>⏱ <%= note.duration_minutes %> min</span><% end %></div><% if note.objectives.present? %><div class="mt-5 rounded-2xl bg-emerald-50 p-4"><p class="text-xs font-bold uppercase tracking-wide text-emerald-700">Learning objectives</p><p class="mt-2 line-clamp-3 whitespace-pre-line text-sm leading-6 text-slate-700"><%= note.objectives %></p></div><% end %><p class="mt-5 line-clamp-4 whitespace-pre-line text-sm leading-6 text-slate-600"><%= note.content %></p><% if note.files.attached? %><div class="mt-5 flex flex-wrap gap-2"><% note.files.each do |file| %><%= link_to rails_blob_path(file, disposition: "attachment"), class: "rounded-xl bg-violet-50 px-3 py-2 text-xs font-bold text-violet-700 hover:bg-violet-100" do %>📎 <%= file.filename %><% end %><% end %></div><% end %><div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-4"><span class="text-xs font-semibold text-slate-500"><%= note.teacher.full_name %></span><%= link_to "Edit plan →", edit_lesson_note_path(note), class: "text-sm font-bold text-indigo-700 hover:text-indigo-900" %></div></div></article><% end %></div><% if @lesson_notes.empty? %><div class="mt-8 rounded-3xl border-2 border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-4xl">📝</div><h2 class="mt-4 text-xl font-bold">No lesson plans yet</h2><p class="mt-2 text-sm text-slate-500">Create your first plan and schedule it for an assigned class.</p></div><% end %>
