<% content_for :title, "Edit teacher remark · SchoolOS" %>
<div class="mx-auto max-w-3xl"><%= link_to "← Back to teacher remarks", report_card_remark_templates_path, class: "text-sm font-bold text-indigo-700 hover:text-indigo-900" %><div class="mt-5 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><div class="border-b border-slate-200 bg-gradient-to-r from-indigo-50 to-violet-50 px-6 py-7 sm:px-8"><p class="text-xs font-bold uppercase tracking-widest text-indigo-600">Remark library</p><h1 class="mt-2 text-3xl font-bold text-slate-900">Edit teacher remark</h1><p class="mt-2 text-sm text-slate-600">Changes apply the next time this template is selected. Existing report cards stay unchanged.</p></div><%= form_with model: @template, class: "space-y-6 p-6 sm:p-8" do |form| %><div class="grid gap-5 sm:grid-cols-2"><div><%= form.label :title, "Short name", class: "field-label" %><%= form.text_field :title, required: true, class: "form-input" %></div><div><%= form.label :kind, "Remark category", class: "field-label" %><%= form.select :kind, @kinds.map { |kind| [kind.humanize, kind] }, {}, class: "form-input" %></div></div><div><%= form.label :body, "Remark text", class: "field-label" %><%= form.text_area :body, required: true, rows: 7, class: "form-input resize-y" %></div><label class="flex cursor-pointer items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4"><%= form.check_box :active, class: "h-4 w-4 rounded border-slate-300 text-indigo-600" %><span class="text-sm font-semibold text-slate-800">Make this remark available for selection on report cards</span></label><div class="flex items-center justify-end gap-3 border-t border-slate-100 pt-6"><%= link_to "Cancel", report_card_remark_templates_path, class: "rounded-xl px-5 py-3 text-sm font-bold text-slate-600 hover:bg-slate-100" %><%= form.submit "Save changes", class: "primary-button" %></div><% end %></div></div>
