<% content_for :title, "Academic performance · SchoolOS" %><h1 class="text-3xl font-black">Academic performance report</h1><p class="mt-2 text-slate-500">Class rankings, progress totals, and students who may need support.</p><%= form_with url: academic_report_path, method: :get, class: "mt-6 grid gap-4 rounded-2xl border bg-white p-5 print:hidden md:grid-cols-3 md:items-end" do |form| %><div><%= form.label :classroom_id, "Class", class: "field-label" %><%= form.collection_select :classroom_id, @classrooms, :id, :name, { prompt: "Select class", selected: @classroom&.id }, class: "form-input" %></div><div><%= form.label :term_id, "Term", class: "field-label" %><%= form.select :term_id, options_from_collection_for_select(@classroom&.academic_year&.terms || [], :id, :name, @term&.id), { prompt: "Select term" }, class: "form-input" %></div><div class="flex gap-2"><%= form.submit "Generate", class: "primary-button" %><% if @classroom && @term %><%= link_to "Export CSV", academic_report_path(classroom_id: @classroom.id, term_id: @term.id, format: :csv), class: "rounded-xl bg-emerald-50 px-4 py-3 text-sm font-bold text-emerald-700" %><button type="button" onclick="window.print()" class="rounded-xl bg-indigo-50 px-4 py-3 text-sm font-bold text-indigo-700">Print / PDF</button><% end %></div><% end %><% if @classroom && @term %><h2 class="mt-6 text-xl font-black"><%= @classroom.name %> · <%= @term.name %></h2><div class="mt-3 overflow-x-auto rounded-2xl border bg-white p-6"><table class="w-full text-left"><thead><tr class="border-b"><th class="py-3">Position</th><th>Student</th><th>Score</th><th>Percentage</th><th>Risk</th></tr></thead><tbody><% @rows.each_with_index do |row, index| %><tr class="border-b"><td class="py-3 font-bold"><%= index + 1 %></td><td><%= row[:student].full_name %></td><td><%= row[:earned] %> / <%= row[:possible] %></td><td><%= number_to_percentage(row[:percentage], precision: 1) %></td><td><span class="rounded-full px-3 py-1 text-xs font-bold <%= row[:percentage] < 50 ? 'bg-red-50 text-red-700' : 'bg-emerald-50 text-emerald-700' %>"><%= row[:percentage] < 50 ? "At risk" : "On track" %></span></td></tr><% end %></tbody></table></div><% end %>
