<% content_for :title, "Edit assessment result · SchoolOS" %>
<%= render "shared/form_header", title: "Edit assessment result", back_path: assessments_student_path(@grade.enrollment.student) %>
<div class="mx-auto mb-5 max-w-xl rounded-xl bg-blue-50 p-4 text-sm text-blue-900"><strong><%= @grade.enrollment.student.full_name %></strong><br><%= @grade.assessment.course_section.subject.name %> · <%= @grade.assessment.title %> · Maximum <%= @grade.assessment.maximum_points %></div>
<%= form_with model: @grade, class: "mx-auto max-w-xl space-y-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm" do |form| %><%= render "shared/form_errors", object: @grade %><div><%= form.label :points, class: "field-label" %><%= form.number_field :points, min: 0, max: @grade.assessment.maximum_points, step: 0.01, required: true, class: "form-input" %></div><div><%= form.label :feedback, class: "field-label" %><%= form.text_area :feedback, rows: 4, class: "form-input" %></div><%= form.submit "Update result", class: "primary-button" %><% end %>
